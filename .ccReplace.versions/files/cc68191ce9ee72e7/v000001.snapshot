                            new ProjectNodeViewModel("MainWindow.axaml.cs", "ide/ContextControl.Workbench/Views/MainWindow.axaml.cs", false, "v1")
                        ]),
                        new ProjectNodeViewModel("ViewModels", "ide/ContextControl.Workbench/ViewModels", true, "v1",
                        [
