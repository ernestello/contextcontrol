BEGIN CC-REPLACE
FILE: shaders/culling/frustum_cull.comp
MODE: function
NAME: hiZOcclude
HASH: df7dbb43
---
bool hiZOcclude(vec3 aabbMin, vec3 aabbMax,
                out float outNearestDepth,
                out float outPyramidDepth,
                out float outMipLevel) {
    outNearestDepth = 0.0;
    outPyramidDepth = 0.0;
    outMipLevel = 0.0;

    const bool temporalSafetyFrame = (pc.temporalInfo.y != 0u);
    bool projectedMotion = false;

    vec4 prevRect;
    float prevNearest = 0.0;
    if (!projectAabbToUvRect(pc.prevViewProj, pc.prevViewportUvTransform,
                            aabbMin, aabbMax, prevRect, prevNearest)) {
        if (pc.debugEnabled != 0u) {
            atomicAdd(debugStats.stats[9], 1);  // hiZNearPlaneFail++
        }
        return false;
    }

    // The pyramid was built from the previous frame. Camera movement needs a
    // conservative guard against disocclusion, but sampling the full
    // previous/current union during fast yaw makes the rect enormous and hits
    // unrelated sky/edge texels. Keep using the previous-frame rect when the
    // two projections still mostly overlap; otherwise draw and let the fresh
    // end-of-frame pyramid catch up.
    vec4 cullRect = prevRect;
    float nearestDepth = prevNearest;

    if (temporalSafetyFrame) {
        vec4 currentRect;
        float currentNearest = 0.0;
        if (!projectAabbToUvRect(pc.viewProj, pc.viewportUvTransform,
                                aabbMin, aabbMax, currentRect, currentNearest)) {
            if (pc.debugEnabled != 0u) {
                atomicAdd(debugStats.stats[9], 1);  // hiZNearPlaneFail++
            }
            return false;
        }

        float uvEpsU = 0.5 / max(pc.hiZPyramidInfo.x, 1.0);
        float uvEpsV = 0.5 / max(pc.hiZPyramidInfo.y, 1.0);
        projectedMotion =
            abs(prevRect.x - currentRect.x) > uvEpsU ||
            abs(prevRect.z - currentRect.z) > uvEpsU ||
            abs(prevRect.y - currentRect.y) > uvEpsV ||
            abs(prevRect.w - currentRect.w) > uvEpsV ||
            abs(prevNearest - currentNearest) > HIZ_OCCLUSION_DEPTH_EPSILON;

        if (projectedMotion) {
            float overlapMinX = max(prevRect.x, currentRect.x);
            float overlapMinY = max(prevRect.y, currentRect.y);
            float overlapMaxX = min(prevRect.z, currentRect.z);
            float overlapMaxY = min(prevRect.w, currentRect.w);
            float overlapW = max(overlapMaxX - overlapMinX, 0.0);
            float overlapH = max(overlapMaxY - overlapMinY, 0.0);
            float overlapArea = overlapW * overlapH;
            float prevArea = max((prevRect.z - prevRect.x) * (prevRect.w - prevRect.y), 1e-6);
            float currentArea = max((currentRect.z - currentRect.x) * (currentRect.w - currentRect.y), 1e-6);

            // If the current projection mostly moved away from the previous
            // one, previous-frame depth is no longer a trustworthy occluder.
            if (overlapArea / prevArea < 0.55 || overlapArea / currentArea < 0.55) {
                return false;
            }

            // Reversed-Z: larger depth is nearer. Use the nearer estimate so
            // motion can only reduce culling, not hide newly exposed geometry.
            nearestDepth = max(prevNearest, currentNearest);
        }
    }

    float uvMinX = cullRect.x;
    float uvMinY = cullRect.y;
    float uvMaxX = cullRect.z;
    float uvMaxY = cullRect.w;

    // The pyramid is only valid inside the previous gameplay viewport. Do not
    // let screen-edge padding spill into editor UI/clear-depth pixels, because
    // those zeros make edge chunks fail Hi-Z and get drawn unnecessarily. If
    // motion exposes an area that was outside the previous viewport, draw it
    // instead of using stale depth.
    vec4 prevViewport = viewportBounds(pc.prevViewportUvTransform);
    float viewportMinX = clamp(min(prevViewport.x, prevViewport.z), 0.0, 1.0);
    float viewportMinY = clamp(min(prevViewport.y, prevViewport.w), 0.0, 1.0);
    float viewportMaxX = clamp(max(prevViewport.x, prevViewport.z), 0.0, 1.0);
    float viewportMaxY = clamp(max(prevViewport.y, prevViewport.w), 0.0, 1.0);
    if (viewportMaxX <= viewportMinX || viewportMaxY <= viewportMinY) {
        return false;
    }

    float viewportEpsU = 0.5 / max(pc.hiZPyramidInfo.x, 1.0);
    float viewportEpsV = 0.5 / max(pc.hiZPyramidInfo.y, 1.0);
    if (uvMinX < viewportMinX - viewportEpsU || uvMaxX > viewportMaxX + viewportEpsU ||
        uvMinY < viewportMinY - viewportEpsV || uvMaxY > viewportMaxY + viewportEpsV) {
        return false;
    }

    // Inflate by a tiny screen-space margin before choosing the mip. Exact AABB
    // projection is too brittle for temporal Hi-Z at silhouettes: a far/elevated
    // LOD chunk can expose only a subpixel sliver while the previous frame's
    // pyramid still contains nearby terrain. Padding makes those edge cases
    // conservatively draw instead of punching small holes.
    float padTexels = HIZ_RECT_BASE_PADDING_TEXELS +
                      (projectedMotion ? HIZ_RECT_MOTION_PADDING_TEXELS : 0.0);
    float padU = padTexels / max(pc.hiZPyramidInfo.x, 1.0);
    float padV = padTexels / max(pc.hiZPyramidInfo.y, 1.0);
    uvMinX = clamp(uvMinX - padU, viewportMinX, viewportMaxX);
    uvMaxX = clamp(uvMaxX + padU, viewportMinX, viewportMaxX);
    uvMinY = clamp(uvMinY - padV, viewportMinY, viewportMaxY);
    uvMaxY = clamp(uvMaxY + padV, viewportMinY, viewportMaxY);

    // Degenerate rectangle after clipping -> cannot occlude reliably.
    if (uvMinX >= uvMaxX || uvMinY >= uvMaxY) {
        return false;
    }

    // Select mip level where rect spans ~2 texels.
    // Integer MSB avoids per-thread transcendental log2().
    float rectWidth  = (uvMaxX - uvMinX) * pc.hiZPyramidInfo.x;
    float rectHeight = (uvMaxY - uvMinY) * pc.hiZPyramidInfo.y;
    float maxDim = max(rectWidth, rectHeight);
    uint maxDimInt = uint(max(maxDim, 1.0));
    int mipInt = findMSB(int(maxDimInt));
    mipInt = clamp(mipInt, 0, int(pc.hiZPyramidInfo.z) - 1);
    float mipLevel = float(mipInt);
    outMipLevel = mipLevel;

    // Progressive 4-corner sampling keeps the shader cheap, but voxel crack
    // holes can leave a lone zero-depth texel on one corner. Recover those
    // mixed-zero cases with a single center confirmation at a finer mip.
    float d0 = textureLod(hiZPyramid, vec2(uvMinX, uvMinY), mipLevel).r;
    float d1 = textureLod(hiZPyramid, vec2(uvMaxX, uvMinY), mipLevel).r;
    float d2 = textureLod(hiZPyramid, vec2(uvMinX, uvMaxY), mipLevel).r;
    float d3 = textureLod(hiZPyramid, vec2(uvMaxX, uvMaxY), mipLevel).r;

    uint nonZeroCount = 0u;
    float minNonZero = 1.0;
    float maxNonZero = 0.0;
    accumulatePyramidDepth(d0, nonZeroCount, minNonZero, maxNonZero);
    accumulatePyramidDepth(d1, nonZeroCount, minNonZero, maxNonZero);
    accumulatePyramidDepth(d2, nonZeroCount, minNonZero, maxNonZero);
    accumulatePyramidDepth(d3, nonZeroCount, minNonZero, maxNonZero);

    float pyramidDepth = 0.0;
    if (projectedMotion) {
        float d4 = textureLod(hiZPyramid, vec2(0.5 * (uvMinX + uvMaxX), uvMinY), mipLevel).r;
        float d5 = textureLod(hiZPyramid, vec2(0.5 * (uvMinX + uvMaxX), uvMaxY), mipLevel).r;
        float d6 = textureLod(hiZPyramid, vec2(uvMinX, 0.5 * (uvMinY + uvMaxY)), mipLevel).r;
        float d7 = textureLod(hiZPyramid, vec2(uvMaxX, 0.5 * (uvMinY + uvMaxY)), mipLevel).r;
        float d8 = textureLod(hiZPyramid, vec2(0.5 * (uvMinX + uvMaxX), 0.5 * (uvMinY + uvMaxY)), mipLevel).r;
        accumulatePyramidDepth(d4, nonZeroCount, minNonZero, maxNonZero);
        accumulatePyramidDepth(d5, nonZeroCount, minNonZero, maxNonZero);
        accumulatePyramidDepth(d6, nonZeroCount, minNonZero, maxNonZero);
        accumulatePyramidDepth(d7, nonZeroCount, minNonZero, maxNonZero);
        accumulatePyramidDepth(d8, nonZeroCount, minNonZero, maxNonZero);

        // Fast rotations often place one AABB-rect edge sample over empty sky
        // even though the actual chunk projection remains occluded. Require a
        // valid center and allow one bad edge/corner sample, while preserving
        // the coherence check on the non-zero footprint.
        if (d8 <= 0.0 || nonZeroCount < 8u || !coherentPyramidDepths(nonZeroCount, minNonZero, maxNonZero)) {
            recordPyramidDepthDebug(nonZeroCount > 0u ? minNonZero : 0.0);
            return false;
        }
        pyramidDepth = minNonZero;
    } else if (nonZeroCount == 4u) {
        pyramidDepth = minNonZero;
    } else if (nonZeroCount > 0u && maxDim <= HIZ_HOLE_RECOVERY_MAX_TEXELS) {
        float confirmMipLevel = max(mipLevel - 1.0, 0.0);
        float centerDepth = textureLod(
            hiZPyramid,
            vec2(0.5 * (uvMinX + uvMaxX), 0.5 * (uvMinY + uvMaxY)),
            confirmMipLevel).r;
        accumulatePyramidDepth(centerDepth, nonZeroCount, minNonZero, maxNonZero);
        if (!coherentPyramidDepths(nonZeroCount, minNonZero, maxNonZero)) {
            recordPyramidDepthDebug(nonZeroCount > 0u ? minNonZero : 0.0);
            return false;
        }
        pyramidDepth = minNonZero;
    } else {
        recordPyramidDepthDebug(nonZeroCount > 0u ? minNonZero : 0.0);
        return false;
    }

    recordPyramidDepthDebug(pyramidDepth);
    outNearestDepth = nearestDepth;
    outPyramidDepth = pyramidDepth;
    return nearestDepth < (pyramidDepth - HIZ_OCCLUSION_DEPTH_EPSILON);
}

END CC-REPLACE

