[package]
name = "context-control-app"
version = "0.1.0"
description = "Context Control visual command IDE"
authors = ["Context Control"]
edition = "2021"

[lib]
name = "context_control_app_lib"
crate-type = ["staticlib", "cdylib", "rlib"]

[build-dependencies]
tauri-build = { version = "2", features = [] }

[dependencies]
serde = { version = "1", features = ["derive"] }
tauri = { version = "2", features = [] }
