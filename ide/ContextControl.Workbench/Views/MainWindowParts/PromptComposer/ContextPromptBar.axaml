<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ContextControl.Workbench.Views.MainWindowParts.ContextPromptBar"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls"
    xmlns:vm="clr-namespace:ContextControl.Workbench.ViewModels"
>
            <Border
                x:Name="PromptBarRoot"
                Classes="cc-prompt-bar"
                Opacity="{Binding ContextControl.PromptBarOpacity}"
                IsHitTestVisible="{Binding ContextControl.IsPromptOpen}"
                ClipToBounds="True"
                VerticalAlignment="Stretch"
                Margin="0">
              <Border.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
                </Transitions>
              </Border.Transitions>
              <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="0">
                <ProgressBar
                    Classes="cc-prompt-progress"
                    Minimum="0"
                    Maximum="100"
                    Value="0"
                    Margin="0,0,0,7"
                    IsVisible="{Binding ContextControl.ShowBusyPromptProgress}"
                    IsIndeterminate="{Binding ContextControl.ShowBusyPromptProgress}" />

                <ItemsControl
                    Grid.Row="1"
                    Margin="0,0,0,6"
                    ItemsSource="{Binding ContextControl.ChatRequestProgressItems}"
                    IsVisible="{Binding ContextControl.HasChatRequestProgress}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ChatRequestProgressViewModel}">
                      <Border Classes="cc-transfer-progress" Margin="0,0,0,4">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                          <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                            <TextBlock Classes="cc-transfer-title" Text="{Binding Title}" />
                            <TextBlock Grid.Column="1" Classes="cc-transfer-meta" Text="{Binding SizeLabel}" />
                            <TextBlock Grid.Column="2" Classes="cc-transfer-meta" Text="{Binding SpeedLabel}" />
                            <Button
                                Grid.Column="3"
                                Classes="cc-prompt-chip"
                                Content="Stop"
                                IsVisible="{Binding IsCancellable}"
                                Command="{Binding DataContext.ContextControl.CancelCodexRequestCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                          </Grid>
                          <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <ProgressBar
                                Classes="cc-transfer-bar"
                                Minimum="0"
                                Maximum="100"
                                Value="{Binding Value}"
                                IsIndeterminate="{Binding IsIndeterminate}" />
                            <TextBlock Grid.Column="1" Classes="cc-transfer-percent" Text="{Binding ElapsedLabel}" />
                          </Grid>
                          <TextBlock Grid.Row="2" Classes="cc-prompt-meta" Text="{Binding Status}" TextWrapping="NoWrap" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border
                    Grid.Row="2"
                    Classes="cc-transfer-progress"
                    IsVisible="{Binding ContextControl.IsTransferProgressActive}">
                  <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="6">
                      <TextBlock Classes="cc-transfer-title" Text="{Binding ContextControl.TransferProgressTitle}" />
                      <TextBlock Grid.Column="1" Classes="cc-transfer-meta" Text="{Binding ContextControl.TransferProgressSizeLabel}" />
                      <TextBlock Grid.Column="2" Classes="cc-transfer-meta" Text="{Binding ContextControl.TransferProgressSpeedLabel}" />
                      <Button
                          Grid.Column="3"
                          Classes="cc-prompt-chip"
                          Content="‹"
                          ToolTip.Tip="Previous install status"
                          Command="{Binding ContextControl.PreviousTransferStatusCommand}" />
                      <TextBlock Grid.Column="4" Classes="cc-transfer-meta" Text="{Binding ContextControl.TransferProgressHistoryPositionLabel}" />
                      <Button
                          Grid.Column="5"
                          Classes="cc-prompt-chip"
                          Content="›"
                          ToolTip.Tip="Next install status"
                          Command="{Binding ContextControl.NextTransferStatusCommand}" />
                      <Button
                          Grid.Column="6"
                          Classes="cc-prompt-chip"
                          Content="x"
                          ToolTip.Tip="Stop current progress or close completed status"
                          Command="{Binding ContextControl.CloseTransferProgressCommand}" />
                    </Grid>
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                      <ProgressBar
                          Classes="cc-transfer-bar"
                          Minimum="0"
                          Maximum="100"
                          Value="{Binding ContextControl.TransferProgressValue}"
                          IsIndeterminate="{Binding ContextControl.IsTransferProgressIndeterminate}" />
                      <TextBlock Grid.Column="1" Classes="cc-transfer-percent" Text="{Binding ContextControl.TransferProgressPercentLabel}" />
                    </Grid>
                    <TextBlock
                        Grid.Row="2"
                        Classes="cc-prompt-meta"
                        Text="{Binding ContextControl.TransferProgressStatus}"
                        TextWrapping="NoWrap" />
                  </Grid>
                </Border>

                <Border x:Name="ContextPromptComposer" Grid.Row="3" Classes="cc-prompt-composer" ClipToBounds="True">
                      <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="5" MinHeight="0" ClipToBounds="True">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                      <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding ContextControl.IsPromptModeSwitcherVisible}">
                        <Button
                            Classes="cc-prompt-mode"
                            Classes.active="{Binding ContextControl.IsContextPromptMode}"
                            Content="{Binding ContextControl.PromptPrimaryModeButtonLabel}"
                            ToolTip.Tip="{Binding ContextControl.PromptPrimaryModeButtonToolTip}"
                            Command="{Binding ContextControl.SwitchPromptToContextCommand}" />
                        <Button
                            Classes="cc-prompt-mode"
                            Classes.active="{Binding ContextControl.IsCodexPromptMode}"
                            Content="Codex"
                            ToolTip.Tip="Codex CLI through the ContextControl flow"
                            Command="{Binding ContextControl.SwitchPromptToCodexCommand}" />
                        <Button
                            Classes="cc-prompt-mode"
                            Classes.active="{Binding ContextControl.IsTerminalPromptMode}"
                            Content="Term"
                            ToolTip.Tip="Install and model download terminal"
                            Command="{Binding ContextControl.SwitchPromptToTerminalCommand}" />
                      </StackPanel>
                      <Border Grid.Column="1" Classes="cc-prompt-status-pill">
                        <TextBlock Text="{Binding ContextControl.PhaseTitle}" Classes="cc-prompt-status" />
                      </Border>
                      <TextBlock Grid.Column="2" Text="{Binding ContextControl.PhaseDetail}" Classes="cc-prompt-detail" />
                      <Button
                          Grid.Column="3"
                          Classes="cc-prompt-chip"
                          IsVisible="{Binding ContextControl.IsCcPromptChromeVisible}"
                          Content="{Binding ContextControl.CcTimelineToggleLabel}"
                          ToolTip.Tip="{Binding ContextControl.CurrentCcStationLabel}"
                          Command="{Binding ContextControl.ToggleCcTimelineCommand}" />
                      <Button
                          Grid.Column="4"
                          Classes="cc-prompt-chip"
                          IsVisible="{Binding ContextControl.IsCcPromptChromeVisible}"
                          Content="{Binding ContextControl.AutopilotModeLabel}"
                          ToolTip.Tip="{Binding ContextControl.AutopilotModeToolTip}"
                          Command="{Binding ContextControl.ToggleAutopilotCommand}" />
                      <Button
                          Grid.Column="5"
                          Classes="cc-prompt-icon"
                          Content="x"
                          ToolTip.Tip="Close prompt"
                          Command="{Binding ContextControl.ClosePromptCommand}" />
                    </Grid>

                    <Border Grid.Row="1" Classes="cc-timeline-panel" IsVisible="{Binding ContextControl.IsCcTimelinePanelVisible}">
                      <ItemsControl
                          HorizontalAlignment="Center"
                          ItemsSource="{Binding ContextControl.CcTimelineStages}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="{x:Type vm:CcTimelineStageViewModel}">
                            <Border
                                Classes="cc-timeline-stop"
                                Classes.current="{Binding IsCurrent}"
                                Classes.complete="{Binding IsComplete}"
                                ToolTip.Tip="{Binding Detail}">
                              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4" VerticalAlignment="Center">
                                <TextBlock Classes="cc-timeline-marker" Text="{Binding Marker}" />
                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="0">
                                  <TextBlock Classes="cc-timeline-title" Text="{Binding Title}" />
                                  <TextBlock Grid.Row="1" Classes="cc-timeline-state" Text="{Binding StateLabel}" />
                                </Grid>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Border>

                    <TextBox
                        x:Name="ContextPromptTextBox"
                        Grid.Row="2"
                        Classes="cc-prompt-input"
                        MinHeight="0"
                        IsVisible="{Binding ContextControl.IsMessagePromptMode}"
                        AcceptsReturn="True"
                        TextWrapping="{Binding ContextControl.PromptTextWrapping}"
                        Watermark="{Binding ContextControl.PromptWatermark}"
                        GotFocus="OnPromptTextBoxGotFocus"
                        LostFocus="OnPromptTextBoxLostFocus"
                        KeyDown="OnPromptTextBoxKeyDown"
                        TextChanged="OnPromptTextBoxTextChanged"
                        ScrollViewer.AllowAutoHide="True"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.HorizontalScrollBarVisibility="{Binding ContextControl.PromptHorizontalScrollBarVisibility}"
                        controls:HoverScrollbarBehavior.IsEnabled="True"
                        controls:HoverScrollbarBehavior.ReserveRight="12"
                        Text="{Binding ContextControl.PromptText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox
                        Grid.Row="2"
                        Classes="cc-terminal-output"
                        MinHeight="0"
                        IsVisible="{Binding ContextControl.IsTerminalPromptMode}"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        TextWrapping="Wrap"
                        ScrollViewer.AllowAutoHide="True"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        controls:HoverScrollbarBehavior.IsEnabled="True"
                        controls:HoverScrollbarBehavior.ReserveRight="12"
                        Text="{Binding ContextControl.TerminalOutputText}" />

                    <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="7" Margin="0,1,0,2">
                      <StackPanel Orientation="Horizontal" Spacing="5" IsVisible="{Binding ContextControl.IsCcPromptActionRowVisible}">
                        <Button Classes="cc-prompt-chip" Content="DIR" ToolTip.Tip="Create directory context" Command="{Binding ContextControl.RunDirCommand}" />
                        <Button Classes="cc-prompt-chip" Content="CC" ToolTip.Tip="Create selected code context" Command="{Binding ContextControl.RunCcCommand}" />
                        <Button Classes="cc-prompt-chip" Content="GO" ToolTip.Tip="Preview patch blocks" Command="{Binding ContextControl.RunGoCommand}" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="5" IsVisible="{Binding ContextControl.IsTerminalPromptMode}">
                        <Button Classes="cc-prompt-chip" Content="Clear" ToolTip.Tip="Clear terminal output" Command="{Binding ContextControl.ClearTerminalCommand}" />
                      </StackPanel>
                      <ComboBox
                          Grid.Column="1"
                          Classes="cc-local-model-picker"
                          IsVisible="{Binding ContextControl.IsContextPromptMode}"
                          ItemsSource="{Binding ContextControl.ActiveInstalledLocalModels}"
                          SelectedItem="{Binding ContextControl.SelectedActiveLocalModel, Mode=TwoWay}"
                          MaxDropDownHeight="180">
                        <ComboBox.ItemTemplate>
                          <DataTemplate DataType="{x:Type vm:LocalLlmModelViewModel}">
                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" IsVisible="{Binding ContextControl.IsMessagePromptMode}">
                        <Border Classes="cc-prompt-status-pill" IsVisible="{Binding ContextControl.HasPromptModelCapabilityHint}">
                          <TextBlock Text="{Binding ContextControl.PromptModelCapabilityHint}" Classes="cc-prompt-status" />
                        </Border>
                        <TextBlock Text="{Binding ContextControl.PromptFooterSummary}" Classes="cc-prompt-meta" VerticalAlignment="Center" />
                      </StackPanel>
                      <TextBlock Grid.Column="2" Text="{Binding ContextControl.TransferProgressStatus}" Classes="cc-prompt-meta" IsVisible="{Binding ContextControl.IsTerminalPromptMode}" />
                      <Button
                          Grid.Column="3"
                          Classes="cc-prompt-send"
                          IsVisible="{Binding ContextControl.IsMessagePromptMode}"
                          Content="{Binding ContextControl.PromptSendButtonLabel}"
                          Command="{Binding ContextControl.SendCommand}" />
                    </Grid>
                  </Grid>
                </Border>
              </Grid>
            </Border>
</UserControl>
