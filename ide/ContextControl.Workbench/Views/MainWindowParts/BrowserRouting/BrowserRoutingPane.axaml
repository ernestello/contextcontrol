<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ContextControl.Workbench.Views.MainWindowParts.BrowserRoutingPane"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls"
    xmlns:vm="clr-namespace:ContextControl.Workbench.ViewModels"
>
      <Border
          Grid.Column="2"
          Classes="panel cc-dock"
          ClipToBounds="True"
          IsVisible="{Binding IsBrowserRoutingPaneOpen}"
          IsHitTestVisible="{Binding IsBrowserRoutingPaneOpen}">
        <Grid RowDefinitions="43,Auto,Auto,Auto,*" RowSpacing="8">
          <Border Grid.Row="0" Classes="pane-header" Padding="12,0">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Context Control" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
              </StackPanel>
              <Button
                  Grid.Column="1"
                  Classes="tree-detail-toggle"
                  Content="x"
                  ToolTip.Tip="Close browser routing window"
                  Command="{Binding ToggleBrowserRoutingPaneCommand}" />
            </Grid>
          </Border>

          <Grid Grid.Row="1" Margin="10,0,10,0" ColumnDefinitions="*,Auto" ColumnSpacing="6">
            <Button
                Classes="cc-dock-tab"
                Classes.active="{Binding ContextControl.IsLogPanelOpen}"
                Content="LOG"
                Command="{Binding ContextControl.SelectLogPanelCommand}" />
            <Button
                Grid.Column="1"
                Classes="header-mini"
                Content="Copy"
                ToolTip.Tip="Copy routing log output"
                Command="{Binding ContextControl.CopyRoutingLogCommand}" />
          </Grid>

          <Grid Grid.Row="2" Margin="10,0,10,0" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
            <ComboBox
                Classes="cc-route-picker"
                HorizontalAlignment="Stretch"
                MaxDropDownHeight="180"
                ItemsSource="{Binding ContextControl.RouteOptions}"
                SelectedItem="{Binding ContextControl.SelectedRoute, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
              <StackPanel>
                <TextBlock Text="{Binding ContextControl.PhaseTitle}" Classes="cc-state-title" />
                <TextBlock Text="{Binding ContextControl.PhaseDetail}" Classes="cc-state-detail" />
              </StackPanel>
              <Button
                  Grid.Column="1"
                  Classes="header-mini"
                  Content="{Binding ContextControl.CcTimelineToggleLabel}"
                  ToolTip.Tip="{Binding ContextControl.CurrentCcStationLabel}"
                  Command="{Binding ContextControl.ToggleCcTimelineCommand}" />
              <Button
                  Grid.Column="2"
                  Classes="header-mini"
                  Content="{Binding ContextControl.AutopilotModeLabel}"
                  ToolTip.Tip="{Binding ContextControl.AutopilotModeToolTip}"
                  Command="{Binding ContextControl.ToggleAutopilotCommand}" />
              <TextBlock
                  Grid.Column="3"
                  Classes="cc-busy"
                  Text="running"
                  IsVisible="{Binding ContextControl.IsBusy}" />
            </Grid>

            <Border Grid.Row="2" Classes="cc-root-info">
              <Grid ColumnDefinitions="38,*" ColumnSpacing="6">
                <TextBlock Text="root" Classes="cc-log-level" />
                <TextBlock
                    Grid.Column="1"
                    Text="{Binding ContextControl.ContextRootLabel}"
                    Classes="path-text"
                    ToolTip.Tip="{Binding ContextControl.ContextRootPath}" />
              </Grid>
            </Border>
          </Grid>

          <Grid Grid.Row="3" Margin="10,0,10,0" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="5">
            <TextBlock Text="{Binding ContextControl.PatchSummary}" Classes="cc-state-detail" />
            <Border Grid.Row="1" Classes="cc-log-host" MaxHeight="118" IsVisible="{Binding ContextControl.HasPatchPlanActions}">
              <ScrollViewer
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  controls:HoverScrollbarBehavior.IsEnabled="True"
                  controls:HoverScrollbarBehavior.ReserveRight="12">
                <ItemsControl ItemsSource="{Binding ContextControl.PatchPlanActions}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PatchPlanActionViewModel}">
                      <Grid ColumnDefinitions="34,34,*" ColumnSpacing="5" Margin="0,0,0,3">
                        <TextBlock Text="{Binding AddedLabel}" Classes="history-meta plus" TextAlignment="Right" FontWeight="Black" />
                        <TextBlock Grid.Column="1" Text="{Binding RemovedLabel}" Classes="history-meta minus" TextAlignment="Right" FontWeight="Black" />
                        <TextBlock Grid.Column="2" Text="{Binding Summary}" Classes="cc-log-message" TextTrimming="CharacterEllipsis" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
            <TextBlock Grid.Row="2" Text="{Binding ContextControl.LastExportPath}" Classes="path-text" />
            <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="6">
              <Button
                  Classes="header-mini primary"
                  Content="Apply effective"
                  Command="{Binding ContextControl.ApplyPatchCommand}" />
              <Button
                  Grid.Column="1"
                  Classes="header-mini"
                  Content="Apply all"
                  Command="{Binding ContextControl.ApplyAllPatchCommand}" />
            </Grid>
          </Grid>

          <Grid Grid.Row="4" Margin="10,0,10,10" RowDefinitions="*,Auto" RowSpacing="8" MinHeight="0">
            <Border Grid.Row="0" Classes="cc-log-host" IsVisible="{Binding ContextControl.IsLogPanelOpen}">
              <ScrollViewer
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  controls:HoverScrollbarBehavior.IsEnabled="True"
                  controls:HoverScrollbarBehavior.ReserveRight="12">
                <ItemsControl ItemsSource="{Binding ContextControl.LogEntries}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ContextControlLogEntryViewModel}">
                      <Grid ColumnDefinitions="42,34,*" ColumnSpacing="5" Margin="0,0,0,3">
                        <TextBlock Text="{Binding Time}" Classes="history-meta" />
                        <TextBlock Grid.Column="1" Text="{Binding Level}" Classes="cc-log-level" />
                        <TextBlock Grid.Column="2" Text="{Binding Message}" Classes="cc-log-message" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>

            <Grid
                x:Name="AttachmentRegion"
                Grid.Row="1"
                MinHeight="0"
                ClipToBounds="True"
                SizeChanged="OnAttachmentRegionSizeChanged">
              <Grid RowDefinitions="Auto,Auto" RowSpacing="6" MinHeight="126" VerticalAlignment="Bottom" IsVisible="{Binding ContextControl.HasAttachments}">
                <TextBlock Text="Pending attachments:" Classes="cc-attachment-title" />
                <Border x:Name="AttachmentListHost" Grid.Row="1" Classes="cc-attachment-host">
                  <ListBox
                      x:Name="AttachmentList"
                      Classes="attachment-list"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"
                      BorderThickness="0"
                      ItemsSource="{Binding ContextControl.Attachments}"
                      SelectionMode="Single"
                      controls:HoverScrollbarBehavior.IsEnabled="True"
                      controls:HoverScrollbarBehavior.ReserveRight="12"
                      ScrollViewer.AllowAutoHide="True"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Styles>
                      <Style Selector="ListBox#AttachmentList > ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,4" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                      </Style>
                      <Style Selector="ListBox#AttachmentList > ListBoxItem:selected">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                      </Style>
                      <Style Selector="ListBox#AttachmentList > ListBoxItem:pointerover">
                        <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
                      </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:ContextControlAttachmentViewModel}">
                        <Border
                            Classes="cc-attachment-row"
                            HorizontalAlignment="Stretch"
                            Tapped="OnAttachmentRowTapped"
                            ToolTip.Tip="{Binding Path}">
                          <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="7">
                            <Border
                                Classes="cc-attachment-ext-tag"
                                Background="{Binding ExtensionTagBackground}"
                                BorderBrush="{Binding ExtensionTagBorder}">
                              <TextBlock
                                  Text="{Binding ExtensionTagText}"
                                  Foreground="{Binding ExtensionTagForeground}"
                                  Classes="cc-attachment-ext-tag-text" />
                            </Border>
                            <TextBlock
                                Grid.Column="1"
                                Text="{Binding DisplayTitle}"
                                Classes="path-text"
                                VerticalAlignment="Center" />
                            <Button
                                Grid.Column="2"
                                Classes="cc-prompt-chip"
                                Content="{Binding IncludeLabel}"
                                Command="{Binding DataContext.ContextControl.ToggleAttachmentIncludeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                            <Border
                                Grid.Column="3"
                                Classes="cc-attachment-remove"
                                Tapped="OnAttachmentRemoveTapped"
                                ToolTip.Tip="Remove attachment">
                              <TextBlock Text="x" Classes="cc-attachment-remove-text" />
                            </Border>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>
              </Grid>
            </Grid>
          </Grid>
        </Grid>
      </Border>
</UserControl>
