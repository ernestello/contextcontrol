<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ContextControl.Workbench.Views.MainWindowParts.WorkspaceHeaderBar"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls"
    xmlns:svc="clr-namespace:ContextControl.Workbench.Services"
    xmlns:vm="clr-namespace:ContextControl.Workbench.ViewModels"
>
          <Grid RowDefinitions="30,42">
            <Border Grid.Row="0" Classes="workspace-mode-bar" Padding="6,0">
              <Grid ColumnDefinitions="*,Auto,Auto,*" ColumnSpacing="10">
                <ItemsControl
                    Grid.Column="1"
                    ItemsSource="{Binding WorkspaceModes}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="5" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:WorkbenchModeOptionViewModel}">
                      <Button
                          Classes="workspace-mode-button"
                          Classes.active="{Binding IsActive}"
                          Content="{Binding Name}"
                          Command="{Binding DataContext.SwitchWorkspaceModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                          CommandParameter="{Binding}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button
                    Grid.Column="2"
                    Classes="header-mini"
                    Content="{Binding UpdateButtonLabel}"
                    Command="{Binding CheckForUpdatesCommand}"
                    ToolTip.Tip="{Binding UpdateStatusLabel}"
                    VerticalAlignment="Center" />

                <ScrollViewer
                    Grid.Column="3"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled"
                    controls:HoverScrollbarBehavior.IsEnabled="True"
                    controls:HoverScrollbarBehavior.ReserveBottom="10"
                    IsVisible="{Binding IsBrowserMode}">
                  <ItemsControl ItemsSource="{Binding BrowserPane.Tabs}" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="4" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:BrowserTabViewModel}">
                        <Border
                            Classes="browser-tab"
                            Classes.active="{Binding IsActive}"
                            PointerPressed="OnBrowserTabPointerPressed">
                          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="5">
                            <TextBlock
                                Text="{Binding Title}"
                                Classes="browser-tab-title"
                                ToolTip.Tip="{Binding Url}" />
                            <Button
                                Grid.Column="1"
                                Classes="browser-tab-close"
                                Content="x"
                                Click="OnBrowserTabCloseClick"
                                ToolTip.Tip="Close tab" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsCodeEditorMode}">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="{Binding ActiveDocument.Name}" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding ActiveDocument.Path}" Classes="editor-meta" Margin="0,2,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding ActiveDocument.Loc}" Classes="editor-meta loc" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBlock Grid.Column="2" Text="{Binding ActiveDocument.Language}" Classes="editor-meta type" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBlock Grid.Column="3" Text="{Binding ActiveDocument.Version}" Classes="editor-meta version" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBlock Grid.Column="4" Text="{Binding ActiveDocument.Bytes}" Classes="editor-meta bytes" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBlock Grid.Column="5" Text="{Binding ActiveDocument.AddedChangeLabel}" Classes="editor-meta plus" IsVisible="{Binding ActiveDocument.HasChangeLabels}" VerticalAlignment="Center" FontWeight="Black" />
                <TextBlock Grid.Column="6" Text="{Binding ActiveDocument.RemovedChangeLabel}" Classes="editor-meta minus" IsVisible="{Binding ActiveDocument.HasChangeLabels}" VerticalAlignment="Center" FontWeight="Black" />
                <TextBlock Grid.Column="7" Text="{Binding ActiveDocument.Status}" Classes="editor-meta" VerticalAlignment="Center" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsChatMode}">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="CC Chat" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding ContextControl.PromptContextPressureLabel}" Classes="editor-meta" Margin="0,2,0,0" />
                  <TextBlock Text="{Binding ContextControl.PromptTokenomicsLabel}" Classes="scanner-status" />
                </StackPanel>
                <ComboBox
                    Grid.Column="1"
                    Classes="cc-local-model-picker"
                    ItemsSource="{Binding ContextControl.InstalledLocalModels}"
                    SelectedItem="{Binding ContextControl.SelectedLocalModel, Mode=TwoWay}"
                    MaxDropDownHeight="180">
                  <ComboBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:LocalLlmModelViewModel}">
                      <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button
                    Grid.Column="2"
                    Classes="browser-open-button"
                    Content="Refresh"
                    Command="{Binding ContextControl.RefreshLocalModelsCommand}" />
                <Button
                    Grid.Column="3"
                    Classes="browser-open-button primary"
                    Content="Prompt"
                    Command="{Binding ContextControl.OpenPromptCommand}" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsImageGenMode}">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Image Gen" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding ContextControl.ImageGenerationModelSummary}" Classes="editor-meta" Margin="0,2,0,0" />
                  <TextBlock Text="{Binding ContextControl.PromptTokenomicsLabel}" Classes="scanner-status" />
                </StackPanel>
                <ComboBox
                    Grid.Column="1"
                    Classes="cc-local-model-picker"
                    ItemsSource="{Binding ContextControl.InstalledImageGenerationModels}"
                    SelectedItem="{Binding ContextControl.SelectedImageGenerationModel, Mode=TwoWay}"
                    MaxDropDownHeight="180">
                  <ComboBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:LocalLlmModelViewModel}">
                      <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button
                    Grid.Column="2"
                    Classes="browser-open-button"
                    Content="Refresh"
                    Command="{Binding ContextControl.RefreshLocalModelsCommand}" />
                <Button
                    Grid.Column="3"
                    Classes="browser-open-button primary"
                    Content="Prompt"
                    Command="{Binding ContextControl.OpenPromptCommand}" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="browser-nav-bar" Padding="6,2" IsVisible="{Binding IsBrowserMode}">
              <Grid ColumnDefinitions="24,24,24,*,24,Auto" ColumnSpacing="4">
                <Button
                    Classes="browser-nav-button"
                    Content="‹"
                    IsEnabled="{Binding BrowserPane.CanGoBack}"
                    Click="OnBrowserBackClick"
                    ToolTip.Tip="Back" />
                <Button
                    Grid.Column="1"
                    Classes="browser-nav-button"
                    Content="›"
                    IsEnabled="{Binding BrowserPane.CanGoForward}"
                    Click="OnBrowserForwardClick"
                    ToolTip.Tip="Forward" />
                <Button
                    Grid.Column="2"
                    Classes="browser-nav-button"
                    Content="↻"
                    Click="OnBrowserRefreshClick"
                    ToolTip.Tip="Reload" />
                <TextBox
                    Grid.Column="3"
                    Classes="browser-url-input"
                    Text="{Binding BrowserPane.UrlText, Mode=TwoWay}"
                    Watermark="https://chatgpt.com"
                    KeyDown="OnBrowserUrlKeyDown" />

                <Button
                    Grid.Column="4"
                    Classes="browser-nav-button"
                    Content="+"
                    Click="OnBrowserNewTabClick"
                    ToolTip.Tip="New tab" />

                <Button
                    Grid.Column="5"
                    Classes="browser-open-button"
                    Content="Go"
                    Click="OnBrowserOpenClick" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsLlmsMode}">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Local LLMs" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Classes="header-mini"
                    Content="{Binding ContextControl.LocalLlmOwnershipFilterLabel}"
                    Command="{Binding ContextControl.CycleLocalLlmOwnershipFilterCommand}" />
                <Button
                    Grid.Column="2"
                    Classes="header-mini"
                    Classes.active="{Binding ContextControl.IsLlmInfoExpanded}"
                    Content="{Binding ContextControl.LlmInfoToggleLabel}"
                    Command="{Binding ContextControl.ToggleLlmInfoCommand}" />
                <Button
                    Grid.Column="3"
                    Classes="header-mini"
                    Classes.active="{Binding ContextControl.IsLlmFiltersExpanded}"
                    Content="{Binding ContextControl.LlmFiltersToggleLabel}"
                    Command="{Binding ContextControl.ToggleLlmFiltersCommand}" />
                <Button
                    Grid.Column="4"
                    Classes="browser-open-button primary"
                    Content="{Binding ContextControl.OllamaInstallButtonLabel}"
                    ToolTip.Tip="{Binding ContextControl.OllamaInstallCommandLabel}"
                    Command="{Binding ContextControl.InstallOllamaCommand}" />
                <Button
                    Grid.Column="5"
                    Classes="browser-open-button"
                    Content="Open Page"
                    Command="{Binding ContextControl.OpenOllamaDownloadPageCommand}" />
                <Button
                    Grid.Column="6"
                    Classes="browser-open-button"
                    Content="Refresh"
                    Command="{Binding ContextControl.RefreshLocalModelsCommand}" />
                <Button
                    Grid.Column="7"
                    Classes="browser-open-button"
                    Content="Prompt"
                  Command="{Binding ContextControl.OpenPromptCommand}" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsDependenciesMode}">
              <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="LLM Dependencies" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding ContextControl.DependencySummary}" Classes="editor-meta" Margin="0,2,0,0" />
                  <TextBlock Text="{Binding ContextControl.OllamaModelsDirectoryStatus}" Classes="scanner-status" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Classes="browser-open-button"
                    Content="Refresh"
                    Command="{Binding ContextControl.RefreshLocalModelsCommand}" />
                <Button
                    Grid.Column="2"
                    Classes="browser-open-button"
                    Content="Open Page"
                    Command="{Binding ContextControl.OpenOllamaDownloadPageCommand}" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsSkillbookMode}">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Skillbook" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding ContextControl.SkillbookSummary}" Classes="editor-meta" Margin="0,2,0,0" />
                  <TextBlock Text="{Binding ContextControl.SkillbookProjectPath}" Classes="scanner-status" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding ContextControl.SkillbookGlobalPath}" Classes="path-text" VerticalAlignment="Center" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsProjectGraphMode}">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Architecture graph" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding ProjectGraphSummary}" Classes="editor-meta" Margin="0,2,0,0" />
                  <TextBlock Text="{Binding ProjectGraphSelectedLabel}" Classes="scanner-status" />
                </StackPanel>
                <ItemsControl
                    Grid.Column="1"
                    ItemsSource="{Binding ProjectGraphGenerationColors}"
                    VerticalAlignment="Center">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="5" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ProjectGraphGenerationColorViewModel}">
                      <Button
                          Classes="graph-color-swatch-button"
                          Click="OnProjectGraphColorSwatchClick">
                        <StackPanel Width="14" Spacing="1" HorizontalAlignment="Left">
                          <Border
                              Width="11"
                              Height="11"
                              CornerRadius="2"
                              HorizontalAlignment="Center"
                              Background="{Binding SwatchBrush}"
                              BorderBrush="{DynamicResource PanelBorderBrush}"
                              BorderThickness="1" />
                          <TextBlock
                              Text="{Binding Label}"
                              Foreground="{DynamicResource TextMutedBrush}"
                              FontSize="7"
                              FontWeight="Black"
                              TextAlignment="Center"
                              HorizontalAlignment="Stretch" />
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button
                    Grid.Column="2"
                    Classes="browser-open-button"
                    Content="Export"
                    Click="OnProjectGraphExportClick" />
                <Button
                    Grid.Column="3"
                    Classes="browser-open-button"
                    Content="{Binding ProjectGraphLayoutToggleLabel}"
                    Command="{Binding ToggleProjectGraphLayoutModeCommand}"
                    ToolTip.Tip="Generation 1 sort" />
                <Button
                    Grid.Column="4"
                    Classes="browser-open-button"
                    Content="Fit Layout"
                    Click="OnProjectGraphFitLayoutClick" />
                <Button
                    Grid.Column="5"
                    Classes="browser-open-button"
                    Content="{Binding ProjectGraphTreeToggleLabel}"
                    Command="{Binding ToggleProjectGraphTreePaneCommand}" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsProjectScannerMode}">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Project scanner" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding ProjectScanSummary}" Classes="editor-meta" Margin="0,2,0,0" />
                  <TextBlock Text="{Binding ProjectScanAutoSetupStatus}" Classes="scanner-status" />
                </StackPanel>
                <ToggleButton
                    Grid.Column="1"
                    Classes="browser-open-button scanner-info-button"
                    Content="Info"
                    IsChecked="{Binding ShowProjectScanMetrics, Mode=TwoWay}"
                    ToolTip.Tip="Show or hide project scan counters" />
                <Button
                    Grid.Column="2"
                    Classes="browser-open-button"
                    Content="Copy"
                    Click="OnProjectScannerCopyClick" />
                <Button
                    Grid.Column="3"
                    Classes="browser-open-button"
                    Content="{Binding ProjectScanButtonLabel}"
                    Command="{Binding ScanProjectRulesCommand}"
                    IsEnabled="{Binding CanScanProjectRules}" />
                <Button
                    Grid.Column="4"
                    Classes="browser-open-button primary"
                    Content="Autosetup"
                    Command="{Binding AutoSetupProjectRulesCommand}"
                    IsEnabled="{Binding CanAutoSetupProjectRules}" />
              </Grid>
            </Border>
          </Grid>
</UserControl>
