<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ContextControl.Workbench.Views.MainWindowParts.ConversationPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls"
    xmlns:svc="clr-namespace:ContextControl.Workbench.Services"
    xmlns:vm="clr-namespace:ContextControl.Workbench.ViewModels"
>
            <Border
                Grid.Row="2"
                Classes="editor-body chat-page"
                Padding="0"
                ClipToBounds="True"
                MinHeight="0"
                IsVisible="{Binding IsConversationMode}">
              <Grid ColumnDefinitions="Auto,*" MinHeight="0" ClipToBounds="True">
                <Grid
                    x:Name="ChatHistoryHoverShell"
                    Grid.Column="0"
                    Classes="chat-history-hover-shell"
                    Width="10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    ClipToBounds="True"
                    PointerEntered="OnChatHistoryHoverEntered"
                    PointerExited="OnChatHistoryHoverExited">
                  <Border
                      x:Name="ChatHistoryPanel"
                      Classes="chat-history-panel"
                      Opacity="0"
                      IsHitTestVisible="False">
                  <Grid RowDefinitions="Auto,*" RowSpacing="7" MinHeight="0">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                      <StackPanel VerticalAlignment="Center">
                        <TextBlock Classes="cc-chat-role" Text="{Binding ContextControl.ChatHistoryPanelTitle}" />
                        <TextBlock Classes="history-meta" Text="{Binding ContextControl.ChatHistorySummary}" />
                      </StackPanel>
                      <Button
                          Grid.Column="1"
                          Classes="cc-prompt-chip"
                          Content="Export"
                          Command="{Binding ContextControl.ExportChatCommand}" />
                      <Button
                          Grid.Column="2"
                          Classes="cc-prompt-chip"
                          Content="New"
                          Command="{Binding ContextControl.NewChatSessionCommand}" />
                    </Grid>
                    <ScrollViewer
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        AllowAutoHide="False">
                      <ItemsControl
                          Classes="chat-session-list"
                          ItemsSource="{Binding ContextControl.ChatSessions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="{x:Type vm:ChatSessionViewModel}">
                            <Grid ColumnDefinitions="*,24" ColumnSpacing="4" MinHeight="46" Margin="0,0,0,5">
                              <Button
                                  Classes="chat-session-row"
                                  Classes.active="{Binding IsActive}"
                                  VerticalAlignment="Stretch"
                                  Command="{Binding DataContext.ContextControl.SelectChatSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                                  <TextBlock Text="{Binding Title}" Classes="chat-session-title" />
                                  <TextBlock Grid.Row="1" Text="{Binding Summary}" Classes="history-meta" />
                                </Grid>
                              </Button>
                              <Button
                                  Grid.Column="1"
                                  Classes="chat-session-remove"
                                  VerticalAlignment="Center"
                                  Content="x"
                                  Command="{Binding DataContext.ContextControl.RemoveChatSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Grid>
                  </Border>
                  <Border
                      Width="10"
                      HorizontalAlignment="Left"
                      Background="Transparent" />
                </Grid>

                <ScrollViewer
                    Grid.Column="1"
                    MinWidth="0"
                    Margin="8"
                    ClipToBounds="True"
                    Classes="chat-message-scroll"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    AllowAutoHide="False">
                  <controls:ChatTranscriptRenderControl
                      ClipToBounds="True"
                      Items="{Binding ContextControl.ChatMessages}"
                      ThemeKey="{Binding ThemeKey}"
                      UiFontFamily="{Binding UiFontFamily}"
                      CodeFontFamily="{Binding CodeFontFamily}"
                      OpenAttachmentCommand="{Binding OpenAttachmentCommand}"
                      CopyChatTextCommand="{Binding ContextControl.CopyChatTextCommand}"
                      CreateProjectFromMessageCommand="{Binding ContextControl.CreateProjectFromMessageCommand}"
                      ToggleSnippetCommand="{Binding ContextControl.ToggleSnippetCommand}"
                      CopySnippetCommand="{Binding ContextControl.CopySnippetCommand}"
                      SaveSnippetAsCommand="{Binding ContextControl.SaveSnippetAsCommand}"
                      UseSnippetForCcCommand="{Binding ContextControl.UseSnippetForCcCommand}"
                      PreviewSnippetCommand="{Binding ContextControl.PreviewSnippetCommand}"
                      ToggleThinkingCommand="{Binding ContextControl.ToggleThinkingCommand}" />
                </ScrollViewer>
              </Grid>
            </Border>
</UserControl>
