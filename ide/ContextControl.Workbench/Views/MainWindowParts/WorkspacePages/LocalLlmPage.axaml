<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ContextControl.Workbench.Views.MainWindowParts.LocalLlmPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls"
    xmlns:svc="clr-namespace:ContextControl.Workbench.Services"
    xmlns:vm="clr-namespace:ContextControl.Workbench.ViewModels"
>
            <Border
                Grid.Row="2"
                Classes="editor-body llm-page"
                Padding="6"
                ClipToBounds="True"
                MinHeight="0"
                IsVisible="{Binding IsLlmsMode}">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="6">
                <Border
                    Classes="scanner-metric-strip llm-collapsible-panel"
                    Opacity="{Binding ContextControl.LlmInfoPanelOpacity}"
                    IsVisible="{Binding ContextControl.IsLlmInfoExpanded}">
                  <WrapPanel HorizontalAlignment="Center">
                    <Border Classes="llm-info-pill" ToolTip.Tip="{Binding ContextControl.HardwareSummary}" MinWidth="320">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Classes="llm-info-pill-text" Text="{Binding ContextControl.HardwareSummary}" TextTrimming="None" />
                        <TextBlock Grid.Column="1" Classes="llm-info-pill-text" Text="{Binding ContextControl.LocalLlmVisibleCountLabel}" VerticalAlignment="Center" />
                      </Grid>
                    </Border>
                  </WrapPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Classes="llm-filter-bar llm-collapsible-panel"
                    Opacity="{Binding ContextControl.LlmFiltersPanelOpacity}"
                    IsVisible="{Binding ContextControl.IsLlmFiltersExpanded}">
                  <WrapPanel HorizontalAlignment="Center">
                    <StackPanel Spacing="2" Width="98" Margin="0,0,5,3">
                      <TextBlock Classes="llm-filter-label" Text="sort" />
                      <ComboBox
                          Classes="theme-picker llm-filter-picker"
                          ItemsSource="{Binding ContextControl.LocalLlmSortOptions}"
                          SelectedItem="{Binding ContextControl.SelectedLocalLlmSortOption, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="2" Width="150" Margin="0,0,5,3">
                      <TextBlock Classes="llm-filter-label" Text="provider" />
                      <ComboBox
                          Classes="theme-picker llm-filter-picker"
                          ItemsSource="{Binding ContextControl.LocalLlmProviderFilters}"
                          SelectedItem="{Binding ContextControl.SelectedLocalLlmProviderFilter, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="2" Width="72" Margin="0,0,5,3">
                      <TextBlock Classes="llm-filter-label" Text="run" />
                      <ComboBox
                          Classes="theme-picker llm-filter-picker"
                          ItemsSource="{Binding ContextControl.LocalLlmSourceFilters}"
                          SelectedItem="{Binding ContextControl.SelectedLocalLlmSourceFilter, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="2" Width="90" Margin="0,0,5,3">
                      <TextBlock Classes="llm-filter-label" Text="purpose" />
                      <ComboBox
                          Classes="theme-picker llm-filter-picker"
                          ItemsSource="{Binding ContextControl.LocalLlmPurposeFilters}"
                          SelectedItem="{Binding ContextControl.SelectedLocalLlmPurposeFilter, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="2" Width="92" Margin="0,0,5,3">
                      <TextBlock Classes="llm-filter-label" Text="base" />
                      <ComboBox
                          Classes="theme-picker llm-filter-picker"
                          ItemsSource="{Binding ContextControl.LocalLlmBaseFilters}"
                          SelectedItem="{Binding ContextControl.SelectedLocalLlmBaseFilter, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="2" Width="110" Margin="0,0,5,3">
                      <TextBlock Classes="llm-filter-label" Text="context" />
                      <ComboBox
                          Classes="theme-picker llm-filter-picker"
                          ItemsSource="{Binding ContextControl.LocalLlmContextFilters}"
                          SelectedItem="{Binding ContextControl.SelectedLocalLlmContextFilter, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="2" Width="130" Margin="0,0,5,3">
                      <TextBlock Classes="llm-filter-label" Text="hardware" />
                      <ComboBox
                          Classes="theme-picker llm-filter-picker"
                          ItemsSource="{Binding ContextControl.LocalLlmRequirementFilters}"
                          SelectedItem="{Binding ContextControl.SelectedLocalLlmRequirementFilter, Mode=TwoWay}" />
                    </StackPanel>
                  </WrapPanel>
                </Border>

                <Grid Grid.Row="2">
                  <ScrollViewer
                    Grid.Row="2"
                    controls:HoverScrollbarBehavior.IsEnabled="True"
                    controls:HoverScrollbarBehavior.ReserveRight="12"
                    AllowAutoHide="True"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
                  <controls:LocalLlmCatalogRenderControl
                      Items="{Binding ContextControl.VisibleLocalLlmModels}"
                      PullModelCommand="{Binding ContextControl.PullLocalModelCommand}"
                      ThemeKey="{Binding ThemeKey}"
                      UiFontFamily="{Binding UiFontFamily}"
                      CodeFontFamily="{Binding CodeFontFamily}" />
                  </ScrollViewer>
                  <Border
                      HorizontalAlignment="Center"
                      VerticalAlignment="Bottom"
                      Margin="0,0,0,12"
                      Padding="8,6"
                      CornerRadius="5"
                      BorderThickness="1"
                      Background="{DynamicResource EditorSurfaceBrush}"
                      BorderBrush="{DynamicResource PanelBorderBrush}"
                      IsVisible="{Binding ContextControl.IsLocalLlmSearchOpen}">
                    <TextBox
                        x:Name="LlmSearchBox"
                        Width="260"
                        Classes="graph-search-input"
                        Watermark="Find model"
                        Text="{Binding ContextControl.LocalLlmSearchText, Mode=TwoWay}" />
                  </Border>
                </Grid>
              </Grid>
            </Border>
</UserControl>
