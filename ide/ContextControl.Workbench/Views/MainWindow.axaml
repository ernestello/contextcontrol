<!-- CC-DESC: Defines the Context Control Workbench shell and project info header. -->
<Window
    x:Class="ContextControl.Workbench.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls"
    xmlns:vm="clr-namespace:ContextControl.Workbench.ViewModels"
    Width="1280"
    Height="800"
    MinWidth="920"
    MinHeight="620"
    SystemDecorations="None"
    Title="Context Control"
    Background="{DynamicResource AppBackgroundBrush}"
    KeyDown="OnKeyDown">
<Grid RowDefinitions="31,*">
    <Border Classes="custom-titlebar" PointerPressed="OnTitleBarPointerPressed">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
        <Border Classes="title-icon">
          <TextBlock
              Classes="title-icon-glyph"
              Text="▣"
              />
        </Border>
        <TextBlock
            Grid.Column="1"
            Classes="window-title"
            Text="Context Control"
            />
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2">
          <Button Classes="window-control" Content="-" Click="OnMinimizeClick" />
          <Button Classes="window-control" Content="□" Click="OnMaximizeRestoreClick" />
          <Button Classes="window-control close" Content="x" Click="OnCloseClick" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" RowDefinitions="108,*" RowSpacing="8" Margin="8">
    <Border Classes="panel" Grid.Row="0" Padding="8">
      <Grid ColumnDefinitions="260,*,310" ColumnSpacing="10">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Grid.Row="0">
            <TextBlock Text="Context Control" FontSize="19" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Native IDE shell over the PowerShell core" Margin="0,4,0,0" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
          </StackPanel>

          <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Button Classes="command primary" Content="Open Project" Click="OnOpenProjectClick" />
            <Button Classes="command" Content="New Project" Click="OnNewProjectClick" />
            <Button
                x:Name="ContextParseToggleButton"
                Classes="icon"
                Content="◉▤"
                Click="OnContextParseToggleClick"
                ToolTip.Tip="Context parse mode" />
            <Button Classes="icon" Content="⚙" Click="OnSettingsClick" />
          </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Projects}" VerticalAlignment="Center">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ProjectTabViewModel}">
                  <Button
                      Classes="project-tile"
                      Classes.active="{Binding IsActive}"
                      Command="{Binding DataContext.SelectProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      CommandParameter="{Binding}">
                    <Grid RowDefinitions="38,*" RowSpacing="4">
                      <Border
                          Width="38"
                          Height="38"
                          CornerRadius="7"
                          HorizontalAlignment="Center"
                          Background="{DynamicResource CommandBackgroundBrush}"
                          BorderBrush="{DynamicResource PanelBorderBrush}"
                          BorderThickness="1">
                        <TextBlock
                            Text="{Binding IconText}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="Black"
                            Foreground="{DynamicResource AccentBrush}" />
                      </Border>

                      <TextBlock
                          Grid.Row="1"
                          Text="{Binding Name}"
                          TextWrapping="Wrap"
                          TextAlignment="Center"
                          FontSize="10"
                          FontWeight="Bold"
                          LineHeight="11" />
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Button
              x:Name="ParseProjectsButton"
              Classes="scope-pin"
              Content=""
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              IsVisible="False"
              Tag="main.projects"
              Click="OnContextParseScopeClick" />
        </Grid>

        <Border
            Grid.Column="2"
            Background="{DynamicResource HeaderBackgroundBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8,4"
            ClipToBounds="True"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
          <Grid RowDefinitions="18,*" RowSpacing="2">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8" Height="18">
              <TextBlock
                  Text="{Binding ProjectInfoTitle}"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  FontSize="12.5"
                  FontWeight="ExtraBold"
                  TextTrimming="CharacterEllipsis" />

              <Button
                  Grid.Column="1"
                  Classes="project-info-switch"
                  Height="19"
                  MinHeight="19"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Content="{Binding ProjectInfoSwitchLabel}"
                  Command="{Binding ToggleProjectInfoModeCommand}" />
            </Grid>

            <StackPanel
                Grid.Row="1"
                IsVisible="{Binding IsProjectInfoProjectMode}"
                Spacing="2"
                Margin="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">
              <Border Classes="project-stat" HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="5">
                  <TextBlock Classes="project-stat-key" Text="loc" />
                  <TextBlock Classes="project-stat-value" Grid.Column="1" Text="{Binding CurrentProject.Location}" />
                  <Button x:Name="ParseProjectLocButton" Grid.Column="2" Classes="scope-pin" Content="" IsVisible="False" Tag="main.projectStat.loc" Click="OnContextParseScopeClick" />
                </Grid>
              </Border>

              <Border Classes="project-stat" HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="5">
                  <TextBlock Classes="project-stat-key" Text="files" />
                  <TextBlock Classes="project-stat-value" Grid.Column="1" Text="{Binding CurrentProject.FileCount}" />
                  <Button x:Name="ParseProjectFilesButton" Grid.Column="2" Classes="scope-pin" Content="" IsVisible="False" Tag="main.projectStat.files" Click="OnContextParseScopeClick" />
                </Grid>
              </Border>

              <Border Classes="project-stat" HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="5">
                  <TextBlock Classes="project-stat-key" Text="dirs" />
                  <TextBlock Classes="project-stat-value" Grid.Column="1" Text="{Binding CurrentProject.DirectoryCount}" />
                  <Button x:Name="ParseProjectDirsButton" Grid.Column="2" Classes="scope-pin" Content="" IsVisible="False" Tag="main.projectStat.dirs" Click="OnContextParseScopeClick" />
                </Grid>
              </Border>

              <Border Classes="project-stat" HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="5">
                  <TextBlock Classes="project-stat-key" Text="commit" />
                  <TextBlock Classes="project-stat-value" Grid.Column="1" Text="{Binding CurrentProject.Commit}" />
                  <Button x:Name="ParseProjectCommitButton" Grid.Column="2" Classes="scope-pin" Content="" IsVisible="False" Tag="main.projectStat.commit" Click="OnContextParseScopeClick" />
                </Grid>
              </Border>
            </StackPanel>

            <Grid
                Grid.Row="1"
                IsVisible="{Binding IsProjectInfoHistoryMode}"
                RowDefinitions="*,20"
                RowSpacing="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
              <Border
                  Background="{DynamicResource EditorSurfaceBrush}"
                  BorderBrush="{DynamicResource PanelBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="5"
                  ClipToBounds="True">
                <Grid>
                  <TextBlock
                      Classes="update-empty"
                      Text="No external updates captured yet."
                      IsVisible="{Binding !HasExternalChanges}" />

                  <ScrollViewer
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      IsVisible="{Binding HasExternalChanges}">
                    <ItemsControl ItemsSource="{Binding ExternalChanges}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ExternalChangeItemViewModel}">
                          <Button
                              Classes="external-update-row"
                              Command="{Binding DataContext.OpenExternalChangeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}">
                            <Grid ColumnDefinitions="14,*,32,32,38,58" ColumnSpacing="5">
                              <CheckBox
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  Width="12"
                                  Height="12"
                                  VerticalAlignment="Center" />

                              <TextBlock
                                  Grid.Column="1"
                                  Classes="update-file"
                                  Text="{Binding FileName}" />

                              <TextBlock Grid.Column="2" Classes="history-meta" Text="{Binding AddedLabel}" TextAlignment="Right" FontWeight="Black" Foreground="{DynamicResource GoodBrush}" />
                              <TextBlock Grid.Column="3" Classes="history-meta" Text="{Binding RemovedLabel}" TextAlignment="Right" FontWeight="Black" Foreground="{DynamicResource BadBrush}" />
                              <TextBlock Grid.Column="4" Classes="history-meta" Text="{Binding LocLabel}" TextAlignment="Right" FontWeight="Black" />
                              <TextBlock Grid.Column="5" Classes="history-meta" Text="{Binding VersionFlow}" TextAlignment="Right" FontWeight="Black" Foreground="{DynamicResource AccentBrush}" />
                            </Grid>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </Border>

              <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="5" IsVisible="{Binding HasExternalChanges}">
                <Button
                    Classes="header-mini primary"
                    Content="Accept all edits"
                    Command="{Binding AcceptAllExternalChangesCommand}" />
                <Button
                    Grid.Column="1"
                    Classes="header-mini"
                    Content="Accept final edits"
                    Command="{Binding AcceptFinalExternalChangesCommand}" />
              </Grid>

              <Button
                  x:Name="ParseUpdatesButton"
                  Classes="scope-pin"
                  Content=""
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  IsVisible="False"
                  Tag="main.updates"
                  Click="OnContextParseScopeClick" />
            </Grid>

            <Button
                x:Name="ParseProjectInfoButton"
                Classes="scope-pin"
                Content=""
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                IsVisible="False"
                Tag="main.projectInfo"
                Click="OnContextParseScopeClick" />
          </Grid>
        </Border>

        <Button
            x:Name="ParseHeaderButton"
            Classes="scope-pin"
            Content=""
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            IsVisible="False"
            Tag="main.header"
            Click="OnContextParseScopeClick" />
      </Grid>
    </Border>

    <Grid
        x:Name="WorkspaceRoot"
        Grid.Row="1"
        ColumnDefinitions="300,*"
        ColumnSpacing="8"
        PointerMoved="OnWorkspacePointerMoved">
      <Border x:Name="SidebarPane" Classes="panel" Grid.Column="0" ClipToBounds="True">
        <Grid RowDefinitions="43,*">
          <Border Grid.Row="0" Classes="pane-header" Padding="12,0,9,0">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
              <TextBlock
                  Text="{Binding CurrentProject.Name}"
                  VerticalAlignment="Center"
                  FontSize="11"
                  FontWeight="ExtraBold"
                  Foreground="{DynamicResource TextMutedBrush}"
                  LetterSpacing="0.8" />
              <Button
                  Grid.Column="1"
                  Classes="tree-detail-toggle"
                  Classes.active="{Binding ShowFileDetails}"
                  Content="{Binding FileDetailsToggleLabel}"
                  Command="{Binding ToggleFileDetailsCommand}" />
              <Button
                  x:Name="ParseTreeHeaderButton"
                  Grid.Column="2"
                  Classes="scope-pin"
                  Content=""
                  IsVisible="False"
                  Tag="main.treeHeader"
                  Click="OnContextParseScopeClick" />
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ListBox
                Classes="project-tree"
                ItemsSource="{Binding VisibleTreeRows}"
                SelectedItem="{Binding SelectedTreeRow, Mode=TwoWay}"
                SelectionChanged="OnProjectTreeSelectionChanged"
                SelectionMode="Single"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:TreeRowViewModel}">
                  <Grid ColumnDefinitions="Auto,*,Auto" Height="{Binding RowHeight}" PointerPressed="OnProjectTreeRowPointerPressed">
                    <Border
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Classes="current-row-highlight"
                        IsVisible="{Binding IsCurrent}"
                        Margin="0,0,5,0" />
                    <Border
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Classes="dir-row-highlight"
                        IsVisible="{Binding IsRegularFolder}"
                        Margin="0,1,0,1" />
                    <Grid
                        Grid.Column="0"
                        Width="{Binding RailWidth}"
                        Height="{Binding RowHeight}">
                      <controls:TreeLinesControl
                          Width="{Binding RailWidth}"
                          Height="{Binding RowHeight}"
                          Depth="{Binding Depth}"
                          IsLast="{Binding IsLast}"
                          AncestorContinues="{Binding AncestorContinues}"
                          HasExpandedChildren="{Binding HasExpandedChildren}"
                          IsSpacer="{Binding IsSpacer}"
                          ThemeKey="{Binding DataContext.ThemeKey, RelativeSource={RelativeSource AncestorType=Window}}" />
                      <Button
                          Classes="tree-toggle"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Margin="{Binding ToggleMargin}"
                          IsVisible="{Binding ShowDisclosure}"
                          Command="{Binding DataContext.ToggleNodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                          CommandParameter="{Binding Node}">
                        <controls:DisclosureArrowControl
                            Width="8"
                            Height="8"
                            Angle="{Binding ArrowAngle}"
                            ThemeKey="{Binding DataContext.ThemeKey, RelativeSource={RelativeSource AncestorType=Window}}">
                          <controls:DisclosureArrowControl.Transitions>
                            <Transitions>
                              <DoubleTransition Property="Angle" Duration="0:0:0.08" />
                            </Transitions>
                          </controls:DisclosureArrowControl.Transitions>
                        </controls:DisclosureArrowControl>
                      </Button>
                    </Grid>
                    <TextBlock
                        Grid.Column="1"
                        Classes.folder-name="{Binding IsFolder}"
                        Classes.file-name="{Binding IsFile}"
                        Classes.external-name="{Binding IsExternal}"
                        IsVisible="{Binding HasNode}"
                        Text="{Binding DisplayName}"
                        VerticalAlignment="Center"
                        Margin="3,0,0,0"
                        FontSize="9.5"
                        TextTrimming="CharacterEllipsis" />
                    <Grid
                        Grid.Column="2"
                        ColumnDefinitions="Auto,Auto,Auto"
                        ColumnSpacing="4"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        IsVisible="{Binding HasNode}">
                      <StackPanel
                          Grid.Column="0"
                          Orientation="Horizontal"
                          Spacing="4"
                          IsVisible="{Binding DataContext.ShowFileDetails, RelativeSource={RelativeSource AncestorType=Window}}">
                        <TextBlock
                            Classes="node-file-count"
                            Text="{Binding FileCountLabel}"
                            IsVisible="{Binding ShowFileCountLabel}" />
                        <TextBlock
                            Classes="node-loc-count"
                            Text="{Binding LocMetricLabel}"
                            IsVisible="{Binding ShowLocMetricLabel}" />
                      </StackPanel>
                      <TextBlock
                          Grid.Column="1"
                          Classes="node-type"
                          Classes.dir="{Binding IsRegularFolder}"
                          Classes.obj="{Binding IsFile}"
                          Classes.skip="{Binding IsExternal}"
                          IsVisible="{Binding ShowNodeTypeLabel}"
                          FontWeight="Black"
                          Text="{Binding NodeTypeLabel}" />
                      <TextBlock
                          Grid.Column="2"
                          Classes="node-version"
                          FontWeight="Black"
                          Text="{Binding VersionLabel}"
                          IsVisible="{Binding ShowVersionLabel}" />
                      <controls:IncludeExternalButton
                          Grid.Column="2"
                          Classes="include-external"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          IsVisible="{Binding CanIncludeExternal}"
                          Command="{Binding DataContext.IncludeExternalNodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                          CommandParameter="{Binding Node}" />
                    </Grid>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </ScrollViewer>

          <Button
              x:Name="ParseTreeButton"
              Grid.RowSpan="2"
              Classes="scope-pin"
              Content=""
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,4,6,0"
              IsVisible="False"
              Tag="main.tree"
              Click="OnContextParseScopeClick" />
        </Grid>
      </Border>

      <Grid Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="{Binding HistoryGutter}">
        <Border
            x:Name="HistoryPane"
            Classes="panel"
            Grid.Column="0"
            Width="{Binding HistoryWidth}"
            Opacity="{Binding HistoryOpacity}"
            IsHitTestVisible="{Binding IsHistoryOpen}"
            ClipToBounds="True">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Width" Duration="0:0:0.12" />
              <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
            </Transitions>
          </Border.Transitions>

          <Grid RowDefinitions="*">
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="4">
              <ItemsControl ItemsSource="{Binding SelectedHistory.Versions}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type vm:VersionEntryViewModel}">
                    <Border
                        Classes="history-version"
                        Classes.active="{Binding IsActive}"
                        PointerPressed="OnHistoryVersionPointerPressed">
                      <Grid ColumnDefinitions="34,*,44,44,44" ColumnSpacing="6">
                        <TextBlock
                            Text="{Binding Version}"
                            VerticalAlignment="Center"
                            TextAlignment="Center"
                            FontFamily="{DynamicResource CodeFontFamily}"
                            FontSize="10"
                            FontWeight="Black"
                            Foreground="{DynamicResource AccentBrush}" />

                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding Date}"
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="ExtraBold"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="2" Text="{Binding AddedLabel}" Classes="history-meta" TextAlignment="Right" FontWeight="Black" Foreground="{DynamicResource GoodBrush}" />
                        <TextBlock Grid.Column="3" Text="{Binding RemovedLabel}" Classes="history-meta" TextAlignment="Right" FontWeight="Black" Foreground="{DynamicResource BadBrush}" />
                        <TextBlock Grid.Column="4" Text="{Binding LocLabel}" Classes="history-meta" TextAlignment="Right" FontWeight="Black" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <Button
                x:Name="ParseHistoryButton"
                Classes="scope-pin"
                Content=""
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,4,6,0"
                IsVisible="False"
                Tag="main.history"
                Click="OnContextParseScopeClick" />
          </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource EditorSurfaceBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
          <Grid RowDefinitions="43,*">
            <Border Grid.Row="0" Classes="pane-header" Padding="12,0">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="{Binding ActiveDocument.Name}" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding ActiveDocument.Path}" Classes="editor-meta" Margin="0,2,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding ActiveDocument.Loc}" Classes="editor-meta" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBlock Grid.Column="2" Text="{Binding ActiveDocument.Language}" Classes="editor-meta" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBlock Grid.Column="3" Text="{Binding ActiveDocument.Version}" Classes="editor-meta" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBlock Grid.Column="4" Text="{Binding ActiveDocument.AddedChangeLabel}" Classes="editor-meta" IsVisible="{Binding ActiveDocument.HasChangeLabels}" VerticalAlignment="Center" FontWeight="Black" Foreground="{DynamicResource GoodBrush}" />
                <TextBlock Grid.Column="5" Text="{Binding ActiveDocument.RemovedChangeLabel}" Classes="editor-meta" IsVisible="{Binding ActiveDocument.HasChangeLabels}" VerticalAlignment="Center" FontWeight="Black" Foreground="{DynamicResource BadBrush}" />
                <TextBlock Grid.Column="6" Text="{Binding ActiveDocument.Status}" Classes="editor-meta" VerticalAlignment="Center" />
                <Button x:Name="ParseEditorHeaderButton" Grid.Column="7" Classes="scope-pin" Content="" IsVisible="False" Tag="main.editorHeader" Click="OnContextParseScopeClick" />
              </Grid>
            </Border>

            <controls:CodeEditor
                x:Name="FileEditor"
                Grid.Row="1"
                Background="{DynamicResource EditorSurfaceBrush}"
                DocumentPath="{Binding ActiveDocument.Path}"
                DocumentText="{Binding ActiveDocument.Text}"
                LineChanges="{Binding ActiveDocument.LineChanges}"
                ThemeKey="{Binding ThemeKey}"
                SyntaxThemeKey="{Binding SyntaxThemeKey}" />

            <Button
                x:Name="ParseEditorButton"
                Grid.Row="0"
                Classes="scope-pin"
                Content=""
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,4,6,0"
                IsVisible="False"
                Tag="main.editor"
                Click="OnContextParseScopeClick" />

            <Button
                x:Name="ParseCodePreviewButton"
                Grid.Row="1"
                Classes="scope-pin"
                Content=""
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,4,6,0"
                IsVisible="False"
                Tag="main.codePreview"
                Click="OnContextParseScopeClick" />
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
  </Grid>
</Window>

