<!-- CC-DESC: Defines the Context Control Workbench shell and project info header. -->
<Window
    x:Class="ContextControl.Workbench.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls"
    xmlns:svc="clr-namespace:ContextControl.Workbench.Services"
    xmlns:vm="clr-namespace:ContextControl.Workbench.ViewModels"
    Width="1280"
    Height="800"
    MinWidth="720"
    MinHeight="460"
    CanResize="True"
    SystemDecorations="None"
    Title="Context Control"
    Icon="avares://ContextControl.Workbench/Assets/Icons/contextcontrol64x64.png"
    Background="{DynamicResource AppBackgroundBrush}"
    KeyDown="OnKeyDown">
<Grid RowDefinitions="31,*">
    <Border Classes="custom-titlebar" PointerPressed="OnTitleBarPointerPressed">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
        <StackPanel Orientation="Horizontal" Spacing="2">
          <Button
              x:Name="EditMenuButton"
              Classes="edit-menu"
              ToolTip.Tip="Project actions">
            <Button.Flyout>
              <Flyout Placement="BottomEdgeAlignedLeft">
                <Border Classes="edit-dropdown">
                  <StackPanel Spacing="1">
                    <Button Classes="edit-dropdown-item" Content="Open Project" Click="OnEditOpenProjectClick" />
                    <Button Classes="edit-dropdown-item" Content="New Project" Click="OnEditNewProjectClick" />
                    <Button Classes="edit-dropdown-item" Content="Settings" Click="OnEditSettingsClick" />
                  </StackPanel>
                </Border>
              </Flyout>
            </Button.Flyout>
            <Grid ColumnDefinitions="18,Auto" ColumnSpacing="6">
              <Border Classes="edit-menu-icon">
                <Image
                    Source="{DynamicResource AppMicroIconImage}"
                    Width="16"
                    Height="16"
                    Stretch="Uniform" />
              </Border>
              <TextBlock
                  Grid.Column="1"
                  Text="EDIT"
                  VerticalAlignment="Center"
                  FontSize="11"
                  FontWeight="Black" />
            </Grid>
          </Button>

          <Button
              x:Name="ViewMenuButton"
              Classes="edit-menu"
              ToolTip.Tip="View windows">
            <Button.Flyout>
              <Flyout Placement="BottomEdgeAlignedLeft">
                <Border Classes="edit-dropdown view-dropdown">
                  <StackPanel Spacing="1">
                    <Button Classes="edit-dropdown-item" Content="{Binding ProjectFilesTreeViewLabel}" Command="{Binding ToggleProjectFilesPaneCommand}" />
                    <Button Classes="edit-dropdown-item" Content="{Binding BrowserRoutingWindowViewLabel}" Command="{Binding ToggleBrowserRoutingPaneCommand}" />
                    <Button Classes="edit-dropdown-item" Content="{Binding PromptWindowViewLabel}" Command="{Binding TogglePromptWindowCommand}" />
                  </StackPanel>
                </Border>
              </Flyout>
            </Button.Flyout>
            <TextBlock
                Text="VIEW"
                VerticalAlignment="Center"
                FontSize="11"
                FontWeight="Black" />
          </Button>
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2">
          <Button Classes="window-control" Content="-" Click="OnMinimizeClick" />
          <Button Classes="window-control" Content="□" Click="OnMaximizeRestoreClick" />
          <Button Classes="window-control close" Content="x" Click="OnCloseClick" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" RowDefinitions="42,*" RowSpacing="8" Margin="8">
    <Border Classes="panel" Grid.Row="0" Padding="6">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
        <ScrollViewer
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Disabled"
            controls:HoverScrollbarBehavior.IsEnabled="True"
            controls:HoverScrollbarBehavior.ReserveBottom="10">
          <ItemsControl ItemsSource="{Binding Projects}" VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type vm:ProjectTabViewModel}">
                <Button
                    Classes="project-tile"
                    Classes.active="{Binding IsActive}"
                    Command="{Binding DataContext.SelectProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}">
                  <Grid ColumnDefinitions="20,*" ColumnSpacing="6">
                    <Border Classes="project-tile-icon">
                      <Image
                          Source="{DynamicResource AppMicroIconImage}"
                          Width="16"
                          Height="16"
                          Stretch="Uniform" />
                    </Border>

                    <TextBlock
                        Grid.Column="1"
                        Classes="project-tab-name"
                        Text="{Binding Name}" />
                  </Grid>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
          <Button
              Classes="project-window-toggle"
              Classes.active="{Binding IsProjectFilesPaneOpen}"
              Command="{Binding ToggleProjectFilesPaneCommand}"
              ToolTip.Tip="Project files tree" />
          <Button
              Classes="project-window-toggle"
              Classes.active="{Binding IsBrowserRoutingPaneOpen}"
              Command="{Binding ToggleBrowserRoutingPaneCommand}"
              ToolTip.Tip="Browser routing window" />
          <Button
              Classes="project-window-toggle"
              Classes.active="{Binding ContextControl.IsPromptOpen}"
              Command="{Binding TogglePromptWindowCommand}"
              ToolTip.Tip="Prompt window" />
          <TextBlock
              Classes="project-info-line"
              Text="{Binding CurrentProject.CompactStatsLine}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid
        x:Name="WorkspaceRoot"
        Grid.Row="1"
        Focusable="True"
        ColumnSpacing="8"
        PointerMoved="OnWorkspacePointerMoved">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="{Binding ProjectFilesPaneWidth}" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="{Binding BrowserRoutingPaneWidth}" />
      </Grid.ColumnDefinitions>
      <Border
          x:Name="SidebarPane"
          Classes="panel"
          Grid.Column="0"
          ClipToBounds="True"
          IsVisible="{Binding IsProjectFilesPaneOpen}"
          IsHitTestVisible="{Binding IsProjectFilesPaneOpen}">
        <Grid RowDefinitions="43,*">
          <Border Grid.Row="0" Classes="pane-header" Padding="12,0,9,0">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
              <TextBlock
                  Text="Project files"
                  VerticalAlignment="Center"
                  FontSize="11"
                  FontWeight="ExtraBold"
                  Foreground="{DynamicResource TextMutedBrush}"
                  LetterSpacing="0.8" />
              <Button
                  Grid.Column="1"
                  Classes="tree-detail-toggle"
                  Classes.active="{Binding ShowFileDetails}"
                  Content="{Binding FileDetailsToggleLabel}"
                  Command="{Binding ToggleFileDetailsCommand}" />
              <Button
                  Grid.Column="2"
                  Classes="tree-detail-toggle"
                  Classes.active="{Binding ShowSkippedFiles}"
                  Content="{Binding SkippedFilesToggleLabel}"
                  Command="{Binding ToggleSkippedFilesCommand}" />
              <Button
                  Grid.Column="3"
                  Classes="tree-detail-toggle"
                  Content="x"
                  ToolTip.Tip="Close project files tree"
                  Command="{Binding ToggleProjectFilesPaneCommand}" />
            </Grid>
          </Border>

          <ScrollViewer
              x:Name="ProjectTreeList"
              Grid.Row="1"
              Classes="project-tree-scroll"
              controls:HoverScrollbarBehavior.IsEnabled="True"
              controls:HoverScrollbarBehavior.ReserveRight="12"
              ScrollViewer.AllowAutoHide="True"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">
            <controls:ProjectTreeRenderControl
                x:Name="ProjectTreeView"
                HorizontalAlignment="Stretch"
                Items="{Binding VisibleTreeRows}"
                ShowFileDetails="{Binding ShowFileDetails}"
                ThemeKey="{Binding ThemeKey}"
                UiFontFamily="{Binding UiFontFamily}"
                CodeFontFamily="{Binding CodeFontFamily}"
                PointerPressed="OnProjectTreeViewPointerPressed"
                DoubleTapped="OnProjectTreeViewDoubleTapped" />
          </ScrollViewer>

        </Grid>
      </Border>

      <Grid Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="{Binding HistoryGutter}">
        <Border
            x:Name="HistoryPane"
            Classes="panel"
            Grid.Column="0"
            Width="{Binding HistoryWidth}"
            Opacity="{Binding HistoryOpacity}"
            IsHitTestVisible="{Binding IsHistoryOpen}"
            ClipToBounds="True">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Width" Duration="0:0:0.12" />
              <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
            </Transitions>
          </Border.Transitions>

          <Grid RowDefinitions="*">
            <ScrollViewer
                Grid.Row="0"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Padding="4"
                controls:HoverScrollbarBehavior.IsEnabled="True"
                controls:HoverScrollbarBehavior.ReserveRight="12">
              <ItemsControl ItemsSource="{Binding SelectedHistory.Versions}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type vm:VersionEntryViewModel}">
                    <Border
                        Classes="history-version"
                        Classes.active="{Binding IsActive}"
                        PointerPressed="OnHistoryVersionPointerPressed">
                      <Grid ColumnDefinitions="34,*,44,44,44" ColumnSpacing="6">
                        <TextBlock
                            Text="{Binding Version}"
                            VerticalAlignment="Center"
                            TextAlignment="Center"
                            FontFamily="{DynamicResource CodeFontFamily}"
                            FontSize="10"
                            FontWeight="Black"
                            Foreground="{DynamicResource AccentBrush}" />

                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding Date}"
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="ExtraBold"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="2" Text="{Binding AddedLabel}" Classes="history-meta" TextAlignment="Right" FontWeight="Black" Foreground="{DynamicResource GoodBrush}" />
                        <TextBlock Grid.Column="3" Text="{Binding RemovedLabel}" Classes="history-meta" TextAlignment="Right" FontWeight="Black" Foreground="{DynamicResource BadBrush}" />
                        <TextBlock Grid.Column="4" Text="{Binding LocLabel}" Classes="history-meta" TextAlignment="Right" FontWeight="Black" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True" Margin="0,0,1,0">
          <Grid RowDefinitions="30,Auto,*,Auto">
            <Border Grid.Row="0" Classes="workspace-mode-bar" Padding="6,0">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <ItemsControl ItemsSource="{Binding WorkspaceModes}" VerticalAlignment="Center">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="5" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:WorkbenchModeOptionViewModel}">
                      <Button
                          Classes="workspace-mode-button"
                          Classes.active="{Binding IsActive}"
                          Content="{Binding Name}"
                          Command="{Binding DataContext.SwitchWorkspaceModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                          CommandParameter="{Binding}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ScrollViewer
                    Grid.Column="1"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled"
                    controls:HoverScrollbarBehavior.IsEnabled="True"
                    controls:HoverScrollbarBehavior.ReserveBottom="10"
                    IsVisible="{Binding IsBrowserMode}">
                  <ItemsControl ItemsSource="{Binding BrowserPane.Tabs}" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="4" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:BrowserTabViewModel}">
                        <Border
                            Classes="browser-tab"
                            Classes.active="{Binding IsActive}"
                            PointerPressed="OnBrowserTabPointerPressed">
                          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="5">
                            <TextBlock
                                Text="{Binding Title}"
                                Classes="browser-tab-title"
                                ToolTip.Tip="{Binding Url}" />
                            <Button
                                Grid.Column="1"
                                Classes="browser-tab-close"
                                Content="x"
                                Click="OnBrowserTabCloseClick"
                                ToolTip.Tip="Close tab" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsCodeEditorMode}">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="{Binding ActiveDocument.Name}" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding ActiveDocument.Path}" Classes="editor-meta" Margin="0,2,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding ActiveDocument.Loc}" Classes="editor-meta" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBlock Grid.Column="2" Text="{Binding ActiveDocument.Language}" Classes="editor-meta" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBlock Grid.Column="3" Text="{Binding ActiveDocument.Version}" Classes="editor-meta" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBlock Grid.Column="4" Text="{Binding ActiveDocument.AddedChangeLabel}" Classes="editor-meta" IsVisible="{Binding ActiveDocument.HasChangeLabels}" VerticalAlignment="Center" FontWeight="Black" Foreground="{DynamicResource GoodBrush}" />
                <TextBlock Grid.Column="5" Text="{Binding ActiveDocument.RemovedChangeLabel}" Classes="editor-meta" IsVisible="{Binding ActiveDocument.HasChangeLabels}" VerticalAlignment="Center" FontWeight="Black" Foreground="{DynamicResource BadBrush}" />
                <TextBlock Grid.Column="6" Text="{Binding ActiveDocument.Status}" Classes="editor-meta" VerticalAlignment="Center" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsChatMode}">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="CC Chat" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding ContextControl.PromptContextPressureLabel}" Classes="editor-meta" Margin="0,2,0,0" />
                  <TextBlock Text="{Binding ContextControl.PromptTokenomicsLabel}" Classes="scanner-status" />
                </StackPanel>
                <ComboBox
                    Grid.Column="1"
                    Classes="cc-local-model-picker"
                    ItemsSource="{Binding ContextControl.InstalledLocalModels}"
                    SelectedItem="{Binding ContextControl.SelectedLocalModel, Mode=TwoWay}"
                    MaxDropDownHeight="180">
                  <ComboBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:LocalLlmModelViewModel}">
                      <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button
                    Grid.Column="2"
                    Classes="browser-open-button"
                    Content="Refresh"
                    Command="{Binding ContextControl.RefreshLocalModelsCommand}" />
                <Button
                    Grid.Column="3"
                    Classes="browser-open-button primary"
                    Content="Prompt"
                    Command="{Binding ContextControl.OpenPromptCommand}" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="browser-nav-bar" Padding="6,2" IsVisible="{Binding IsBrowserMode}">
              <Grid ColumnDefinitions="24,24,24,*,24,Auto" ColumnSpacing="4">
                <Button
                    Classes="browser-nav-button"
                    Content="‹"
                    IsEnabled="{Binding BrowserPane.CanGoBack}"
                    Click="OnBrowserBackClick"
                    ToolTip.Tip="Back" />
                <Button
                    Grid.Column="1"
                    Classes="browser-nav-button"
                    Content="›"
                    IsEnabled="{Binding BrowserPane.CanGoForward}"
                    Click="OnBrowserForwardClick"
                    ToolTip.Tip="Forward" />
                <Button
                    Grid.Column="2"
                    Classes="browser-nav-button"
                    Content="↻"
                    Click="OnBrowserRefreshClick"
                    ToolTip.Tip="Reload" />
                <TextBox
                    Grid.Column="3"
                    Classes="browser-url-input"
                    Text="{Binding BrowserPane.UrlText, Mode=TwoWay}"
                    Watermark="https://chatgpt.com"
                    KeyDown="OnBrowserUrlKeyDown" />

                <Button
                    Grid.Column="4"
                    Classes="browser-nav-button"
                    Content="+"
                    Click="OnBrowserNewTabClick"
                    ToolTip.Tip="New tab" />

                <Button
                    Grid.Column="5"
                    Classes="browser-open-button"
                    Content="Go"
                    Click="OnBrowserOpenClick" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsLlmsMode}">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Local LLMs" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding ContextControl.OllamaInstallerSizeLabel}" Classes="editor-meta" Margin="0,2,0,0" />
                  <TextBlock Text="{Binding ContextControl.LocalLlmStatus}" Classes="scanner-status" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Classes="browser-open-button primary"
                    Content="{Binding ContextControl.OllamaInstallButtonLabel}"
                    ToolTip.Tip="{Binding ContextControl.OllamaInstallCommandLabel}"
                    Command="{Binding ContextControl.InstallOllamaCommand}" />
                <Button
                    Grid.Column="2"
                    Classes="browser-open-button"
                    Content="Open Page"
                    Command="{Binding ContextControl.OpenOllamaDownloadPageCommand}" />
                <Button
                    Grid.Column="3"
                    Classes="browser-open-button"
                    Content="Refresh"
                    Command="{Binding ContextControl.RefreshLocalModelsCommand}" />
                <Button
                    Grid.Column="4"
                    Classes="browser-open-button"
                    Content="Prompt"
                    Command="{Binding ContextControl.OpenPromptCommand}" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsSkillbookMode}">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Skillbook" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding ContextControl.SkillbookSummary}" Classes="editor-meta" Margin="0,2,0,0" />
                  <TextBlock Text="{Binding ContextControl.SkillbookProjectPath}" Classes="scanner-status" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding ContextControl.SkillbookGlobalPath}" Classes="path-text" VerticalAlignment="Center" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsProjectGraphMode}">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Architecture graph" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding ProjectGraphSummary}" Classes="editor-meta" Margin="0,2,0,0" />
                  <TextBlock Text="{Binding ProjectGraphSelectedLabel}" Classes="scanner-status" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Classes="browser-open-button"
                    Content="Fit Layout"
                    Click="OnProjectGraphFitLayoutClick" />
                <Button
                    Grid.Column="2"
                    Classes="browser-open-button"
                    Content="{Binding ProjectGraphTreeToggleLabel}"
                    Command="{Binding ToggleProjectGraphTreePaneCommand}" />
                <Button
                    Grid.Column="3"
                    Classes="browser-open-button"
                    Content="Copy Tree"
                    Click="OnProjectGraphCopyTreeClick" />
              </Grid>
            </Border>

            <Border Grid.Row="1" Classes="pane-header" Padding="12,0" IsVisible="{Binding IsProjectScannerMode}">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Project scanner" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding ProjectScanSummary}" Classes="editor-meta" Margin="0,2,0,0" />
                  <TextBlock Text="{Binding ProjectScanAutoSetupStatus}" Classes="scanner-status" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Classes="browser-open-button"
                    Content="Copy"
                    Click="OnProjectScannerCopyClick" />
                <Button
                    Grid.Column="2"
                    Classes="browser-open-button"
                    Content="{Binding ProjectScanButtonLabel}"
                    Command="{Binding ScanProjectRulesCommand}"
                    IsEnabled="{Binding CanScanProjectRules}" />
                <Button
                    Grid.Column="3"
                    Classes="browser-open-button primary"
                    Content="Autosetup"
                    Command="{Binding AutoSetupProjectRulesCommand}"
                    IsEnabled="{Binding CanAutoSetupProjectRules}" />
              </Grid>
            </Border>

            <Border
                Grid.Row="2"
                Classes="editor-body"
                ClipToBounds="True"
                MinHeight="0"
                IsVisible="{Binding IsCodeEditorMode}">
              <controls:CodeEditor
                  x:Name="FileEditor"
                  Background="{DynamicResource EditorSurfaceBrush}"
                  DocumentPath="{Binding ActiveDocument.Path}"
                  DocumentText="{Binding ActiveDocument.Text}"
                  LineChanges="{Binding ActiveDocument.LineChanges}"
                  ThemeKey="{Binding ThemeKey}"
                  SyntaxThemeKey="{Binding SyntaxThemeKey}"
                  CodeFontFamily="{Binding CodeFontFamily}"
                  SkinKey="{Binding SkinKey}"
                  ShowMinimap="{Binding ShowAppearanceCodePreview}"
                  ShowFoldArrows="{Binding ShowFoldArrows}"
                  ShowSummaryArrowBorders="{Binding ShowSummaryArrowBorders}"
                  SummaryFoldKinds="{Binding SummaryFoldKinds}"
                  FoldArrowsInCodeEditor="{Binding FoldArrowsInCodeEditor}"
                  UseParentChildArrowIndentation="{Binding EffectiveUseParentChildArrowIndentation}"
                  ShowVerticalScopeLines="{Binding ShowVerticalScopeLines}"
                  UseColorfulFamilies="{Binding UseColorfulFamilies}" />
            </Border>

            <Border
                Grid.Row="2"
                Classes="editor-body chat-page"
                Padding="8"
                ClipToBounds="True"
                MinHeight="0"
                IsVisible="{Binding IsChatMode}">
              <Grid RowDefinitions="Auto,*" ColumnDefinitions="220,*" RowSpacing="8" ColumnSpacing="8" MinHeight="0">
                <Border Grid.ColumnSpan="2" Classes="scanner-metric-strip">
                  <WrapPanel>
                    <Border Classes="scanner-metric" Width="210">
                      <Grid RowDefinitions="Auto,*" RowSpacing="0">
                        <TextBlock Classes="scanner-metric-key" Text="Prompt" />
                        <TextBlock Grid.Row="1" Classes="scanner-metric-value" Text="{Binding ContextControl.PromptTokenomicsLabel}" />
                      </Grid>
                    </Border>
                    <Border Classes="scanner-metric" Width="260">
                      <Grid RowDefinitions="Auto,*" RowSpacing="0">
                        <TextBlock Classes="scanner-metric-key" Text="Context" />
                        <TextBlock Grid.Row="1" Classes="scanner-metric-value" Text="{Binding ContextControl.PromptContextPressureLabel}" />
                      </Grid>
                    </Border>
                    <Border Classes="scanner-metric" Width="220">
                      <Grid RowDefinitions="Auto,*" RowSpacing="0">
                        <TextBlock Classes="scanner-metric-key" Text="Phase" />
                        <TextBlock Grid.Row="1" Classes="scanner-metric-value" Text="{Binding ContextControl.PhaseTitle}" />
                      </Grid>
                    </Border>
                  </WrapPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Classes="chat-history-panel">
                  <Grid RowDefinitions="Auto,*" RowSpacing="7" MinHeight="0">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                      <StackPanel VerticalAlignment="Center">
                        <TextBlock Classes="cc-chat-role" Text="Chats" />
                        <TextBlock Classes="history-meta" Text="{Binding ContextControl.ChatHistorySummary}" />
                      </StackPanel>
                      <Button
                          Grid.Column="1"
                          Classes="cc-prompt-chip"
                          Content="New"
                          Command="{Binding ContextControl.NewChatSessionCommand}" />
                    </Grid>
                    <ScrollViewer
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        controls:HoverScrollbarBehavior.IsEnabled="True"
                        controls:HoverScrollbarBehavior.ReserveRight="12">
                      <ItemsControl ItemsSource="{Binding ContextControl.ChatSessions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="{x:Type vm:ChatSessionViewModel}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4" Margin="0,0,0,5">
                              <Button
                                  Classes="chat-session-row"
                                  Classes.active="{Binding IsActive}"
                                  Command="{Binding DataContext.ContextControl.SelectChatSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                                  <TextBlock Text="{Binding Title}" Classes="chat-session-title" />
                                  <TextBlock Grid.Row="1" Text="{Binding Summary}" Classes="history-meta" />
                                </Grid>
                              </Button>
                              <Button
                                  Grid.Column="1"
                                  Classes="chat-session-remove"
                                  Content="x"
                                  Command="{Binding DataContext.ContextControl.RemoveChatSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Grid>
                </Border>

                <ScrollViewer
                    Grid.Row="1"
                    Grid.Column="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    controls:HoverScrollbarBehavior.IsEnabled="True"
                    controls:HoverScrollbarBehavior.ReserveRight="12">
                  <ItemsControl ItemsSource="{Binding ContextControl.ChatMessages}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:LocalLlmChatMessageViewModel}">
                        <Border Classes="cc-chat-message" Classes.user="{Binding IsUser}">
                          <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                              <StackPanel>
                                <TextBlock Classes="cc-chat-role" Text="{Binding RoleLabel}" />
                                <TextBlock Classes="history-meta" Text="{Binding MetaLabel}" />
                              </StackPanel>
                              <TextBlock Grid.Column="1" Classes="history-meta" Text="{Binding Time}" />
                            </Grid>

                            <ItemsControl Grid.Row="1" ItemsSource="{Binding AttachedFiles}" IsVisible="{Binding HasAttachments}">
                              <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                  <WrapPanel />
                                </ItemsPanelTemplate>
                              </ItemsControl.ItemsPanel>
                              <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ContextControlAttachmentViewModel}">
                                  <Border Classes="chat-attachment-chip" ToolTip.Tip="{Binding Path}" Tapped="OnAttachmentRowTapped">
                                    <TextBlock Text="{Binding DisplayTitle}" Classes="chat-attachment-chip-text" />
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl Grid.Row="2" ItemsSource="{Binding Parts}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:LocalLlmChatPartViewModel}">
                                  <Grid>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="5" IsVisible="{Binding IsText}">
                                      <SelectableTextBlock
                                          Classes="cc-chat-text"
                                          Text="{Binding Text}" />
                                      <Button
                                          Grid.Column="1"
                                          Classes="chat-text-copy"
                                          Content="⧉"
                                          ToolTip.Tip="Copy message text"
                                          Command="{Binding DataContext.ContextControl.CopyChatTextCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}" />
                                    </Grid>
                                    <Border Classes="chat-snippet" IsVisible="{Binding IsSnippet}">
                                      <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="5">
                                          <StackPanel>
                                            <TextBlock Classes="chat-snippet-title" Text="{Binding Snippet.Title}" />
                                            <TextBlock Classes="history-meta" Text="{Binding Snippet.MetaLabel}" />
                                          </StackPanel>
                                          <Button
                                              Grid.Column="1"
                                              Classes="cc-prompt-chip"
                                              Content="{Binding Snippet.ToggleLabel}"
                                              Command="{Binding DataContext.ContextControl.ToggleSnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                              CommandParameter="{Binding Snippet}" />
                                          <Button
                                              Grid.Column="2"
                                              Classes="cc-prompt-chip"
                                              Content="Copy"
                                              Command="{Binding DataContext.ContextControl.CopySnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                              CommandParameter="{Binding Snippet}" />
                                          <Button
                                              Grid.Column="3"
                                              Classes="cc-prompt-chip"
                                              Content="{Binding Snippet.ActionLabel}"
                                              IsVisible="{Binding Snippet.HasPromptAction}"
                                              Command="{Binding DataContext.ContextControl.UseSnippetForCcCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                              CommandParameter="{Binding Snippet}" />
                                          <Button
                                              Grid.Column="4"
                                              Classes="cc-prompt-chip"
                                              Content="GO"
                                              IsVisible="{Binding Snippet.IsPatch}"
                                              Command="{Binding DataContext.ContextControl.PreviewSnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                              CommandParameter="{Binding Snippet}" />
                                        </Grid>
                                        <TextBlock
                                            Grid.Row="1"
                                            Classes="chat-snippet-preview"
                                            Text="{Binding Snippet.CollapsedPreview}"
                                            IsVisible="{Binding Snippet.IsCollapsed}" />
                                        <TextBox
                                            Grid.Row="2"
                                            Classes="chat-snippet-code"
                                            IsReadOnly="True"
                                            IsVisible="{Binding Snippet.IsExpanded}"
                                            AcceptsReturn="True"
                                            TextWrapping="NoWrap"
                                            Text="{Binding Snippet.Text}"
                                            ScrollViewer.AllowAutoHide="True"
                                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                            controls:HoverScrollbarBehavior.IsEnabled="True"
                                            controls:HoverScrollbarBehavior.ReserveRight="12" />
                                      </Grid>
                                    </Border>
                                  </Grid>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Grid.Row="3" Classes="chat-thinking" IsVisible="{Binding HasThinking}">
                              <Grid RowDefinitions="Auto,Auto" RowSpacing="5">
                                <Button
                                    Classes="cc-prompt-chip"
                                    HorizontalAlignment="Left"
                                    Content="Thinking"
                                    Command="{Binding DataContext.ContextControl.ToggleThinkingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />
                                <TextBox
                                    Grid.Row="1"
                                    Classes="chat-snippet-code"
                                    IsReadOnly="True"
                                    IsVisible="{Binding IsThinkingExpanded}"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    Text="{Binding ThinkingText}" />
                              </Grid>
                            </Border>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </Border>

            <Border
                Grid.Row="2"
                Classes="browser-surface"
                ClipToBounds="True"
                MinHeight="0"
                IsVisible="{Binding IsBrowserMode}">
              <controls:WebView2Host
                  x:Name="BrowserWebView"
                  UserDataFolder="{Binding BrowserPane.NativeUserDataFolder}"
                  NavigationStarted="OnBrowserNavigationStarted"
                  NavigationCompleted="OnBrowserNavigationCompleted"
                  InitializationFailed="OnBrowserInitializationFailed" />
            </Border>

            <Border
                Grid.Row="2"
                Classes="editor-body llm-page"
                Padding="6"
                ClipToBounds="True"
                MinHeight="0"
                IsVisible="{Binding IsLlmsMode}">
              <Grid RowDefinitions="Auto,*" RowSpacing="6">
                <Border Classes="scanner-metric-strip">
                  <WrapPanel>
                    <Border Classes="scanner-metric" Width="190" ToolTip.Tip="{Binding ContextControl.HardwareSummary}">
                      <Grid RowDefinitions="Auto,*" RowSpacing="0">
                        <TextBlock Classes="scanner-metric-key" Text="GPU" />
                        <TextBlock Grid.Row="1" Classes="scanner-metric-value" Text="{Binding ContextControl.HardwareSummary}" />
                      </Grid>
                    </Border>
                    <Border Classes="scanner-metric" Width="130">
                      <Grid RowDefinitions="Auto,*" RowSpacing="0">
                        <TextBlock Classes="scanner-metric-key" Text="Installed" />
                        <TextBlock Grid.Row="1" Classes="scanner-metric-value" Text="{Binding ContextControl.InstalledLocalModels.Count}" />
                      </Grid>
                    </Border>
                    <Border Classes="scanner-metric" Width="290" ToolTip.Tip="{Binding ContextControl.LocalLlmStatus}">
                      <Grid RowDefinitions="Auto,*" RowSpacing="0">
                        <TextBlock Classes="scanner-metric-key" Text="Ollama" />
                        <TextBlock Grid.Row="1" Classes="scanner-metric-value" Text="{Binding ContextControl.LocalLlmStatus}" />
                      </Grid>
                    </Border>
                    <Border Classes="scanner-metric" Width="220" ToolTip.Tip="{Binding ContextControl.OllamaInstallCommandLabel}">
                      <Grid RowDefinitions="Auto,*" RowSpacing="0">
                        <TextBlock Classes="scanner-metric-key" Text="Installer" />
                        <TextBlock Grid.Row="1" Classes="scanner-metric-value" Text="{Binding ContextControl.OllamaInstallerSizeLabel}" />
                      </Grid>
                    </Border>
                  </WrapPanel>
                </Border>

                <ScrollViewer
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    controls:HoverScrollbarBehavior.IsEnabled="True"
                    controls:HoverScrollbarBehavior.ReserveRight="12">
                  <ItemsControl ItemsSource="{Binding ContextControl.LocalLlmModels}" HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Spacing="6" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:LocalLlmModelViewModel}">
                        <Border
                            Classes="llm-model-card"
                            Classes.recommended="{Binding IsRecommended}"
                            Classes.installed="{Binding IsInstalled}"
                            ToolTip.Tip="{Binding SourceBudget}"
                            HorizontalAlignment="Stretch">
                          <Grid ColumnDefinitions="2.2*,3.6*,Auto" ColumnSpacing="10">
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="3" VerticalAlignment="Center">
                              <StackPanel>
                                <TextBlock Classes="llm-model-title" Text="{Binding DisplayName}" />
                                <TextBlock Classes="llm-model-id" Text="{Binding Id}" />
                              </StackPanel>
                              <TextBlock Grid.Row="1" Classes="llm-model-use" Text="{Binding PracticalUse}" />
                              <TextBlock Grid.Row="2" Classes="llm-fit-detail" Text="{Binding FitDetail}" />
                            </Grid>

                            <Grid Grid.Column="1" RowDefinitions="Auto" VerticalAlignment="Center">
                              <WrapPanel>
                                <Border Classes="llm-metric-chip">
                                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
                                    <TextBlock Classes="llm-metric-icon" Text="DL" />
                                    <TextBlock Grid.Column="1" Classes="llm-metric-text" Text="{Binding DownloadSize}" />
                                  </Grid>
                                </Border>
                                <Border Classes="llm-metric-chip">
                                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
                                    <TextBlock Classes="llm-metric-icon" Text="VRAM" />
                                    <TextBlock Grid.Column="1" Classes="llm-metric-text" Text="{Binding MinimumRequirement}" />
                                  </Grid>
                                </Border>
                                <Border Classes="llm-metric-chip">
                                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
                                    <TextBlock Classes="llm-metric-icon" Text="CTX" />
                                    <TextBlock Grid.Column="1" Classes="llm-metric-text" Text="{Binding AdvertisedContext}" />
                                  </Grid>
                                </Border>
                                <Border Classes="llm-metric-chip">
                                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
                                    <TextBlock Classes="llm-metric-icon" Text="OK" />
                                    <TextBlock Grid.Column="1" Classes="llm-metric-text" Text="{Binding ComfortableContext}" />
                                  </Grid>
                                </Border>
                                <Border Classes="llm-metric-chip">
                                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
                                    <TextBlock Classes="llm-metric-icon" Text="TPS" />
                                    <TextBlock Grid.Column="1" Classes="llm-metric-text" Text="{Binding ExpectedSpeed}" />
                                  </Grid>
                                </Border>
                                <Border Classes="llm-metric-chip">
                                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
                                    <TextBlock Classes="llm-metric-icon" Text="LIC" />
                                    <TextBlock Grid.Column="1" Classes="llm-metric-text" Text="{Binding License}" />
                                  </Grid>
                                </Border>
                                <Border Classes="llm-metric-chip">
                                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
                                    <TextBlock Classes="llm-metric-icon" Text="THK" />
                                    <TextBlock Grid.Column="1" Classes="llm-metric-text" Text="{Binding ThinkingLabel}" />
                                  </Grid>
                                </Border>
                              </WrapPanel>
                            </Grid>

                            <Grid Grid.Column="2" RowDefinitions="Auto,Auto" RowSpacing="5" MinWidth="96" VerticalAlignment="Center">
                              <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
                                <Border Classes="llm-pill">
                                  <TextBlock Classes="llm-pill-text" Text="{Binding InstallLabel}" />
                                </Border>
                                <Border Classes="llm-pill recommended" IsVisible="{Binding IsRecommended}">
                                  <TextBlock Classes="llm-pill-text" Text="{Binding FitLabel}" />
                                </Border>
                              </StackPanel>
                              <Button
                                  Grid.Row="1"
                                  Classes="browser-open-button"
                                  HorizontalAlignment="Right"
                                  Content="{Binding PullButtonLabel}"
                                  IsEnabled="{Binding CanPull}"
                                  ToolTip.Tip="{Binding PullCommand}"
                                  Command="{Binding DataContext.ContextControl.PullLocalModelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                            </Grid>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </Border>

            <Border
                Grid.Row="2"
                Classes="editor-body skillbook-page"
                Padding="8"
                ClipToBounds="True"
                MinHeight="0"
                IsVisible="{Binding IsSkillbookMode}">
              <Grid RowDefinitions="Auto,*" RowSpacing="8">
                <Border Classes="scanner-metric-strip">
                  <WrapPanel>
                    <Border Classes="scanner-metric" Width="360" ToolTip.Tip="{Binding ContextControl.SkillbookProjectPath}">
                      <Grid RowDefinitions="Auto,*" RowSpacing="0">
                        <TextBlock Classes="scanner-metric-key" Text="Project Skillbook" />
                        <TextBlock Grid.Row="1" Classes="scanner-metric-value" Text="{Binding ContextControl.SkillbookProjectPath}" />
                      </Grid>
                    </Border>
                    <Border Classes="scanner-metric" Width="360" ToolTip.Tip="{Binding ContextControl.SkillbookGlobalPath}">
                      <Grid RowDefinitions="Auto,*" RowSpacing="0">
                        <TextBlock Classes="scanner-metric-key" Text="Global Skillbook" />
                        <TextBlock Grid.Row="1" Classes="scanner-metric-value" Text="{Binding ContextControl.SkillbookGlobalPath}" />
                      </Grid>
                    </Border>
                  </WrapPanel>
                </Border>

                <ScrollViewer
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    controls:HoverScrollbarBehavior.IsEnabled="True"
                    controls:HoverScrollbarBehavior.ReserveRight="12">
                  <ItemsControl ItemsSource="{Binding ContextControl.SkillbookEntries}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Spacing="7" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:SkillbookEntryViewModel}">
                        <Border Classes="skillbook-entry">
                          <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                              <StackPanel>
                                <TextBlock Classes="llm-model-title" Text="{Binding Title}" />
                                <TextBlock Classes="history-meta" Text="{Binding Summary}" />
                              </StackPanel>
                              <Border Grid.Column="1" Classes="llm-pill">
                                <TextBlock Classes="llm-pill-text" Text="{Binding SourceLabel}" />
                              </Border>
                            </Grid>
                            <TextBox
                                Grid.Row="1"
                                Classes="skillbook-text"
                                IsReadOnly="True"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                Text="{Binding Text}"
                                ScrollViewer.AllowAutoHide="True"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                controls:HoverScrollbarBehavior.IsEnabled="True"
                                controls:HoverScrollbarBehavior.ReserveRight="12" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </Border>

            <Border
                Grid.Row="2"
                Classes="editor-body graph-page"
                Padding="6"
                ClipToBounds="True"
                MinHeight="0"
                IsVisible="{Binding IsProjectGraphMode}">
              <Grid ColumnSpacing="{Binding ProjectGraphTreeColumnSpacing}" MinHeight="0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="{Binding ProjectGraphTreePaneWidth}" />
                </Grid.ColumnDefinitions>
                <Border Classes="graph-surface" ClipToBounds="True" MinHeight="0">
                  <Grid ClipToBounds="True">
                    <controls:ProjectGraphRenderControl
                        x:Name="ProjectGraphView"
                        Items="{Binding ProjectTree}"
                        SelectedNode="{Binding ProjectGraphSelectedNode, Mode=TwoWay}"
                        GraphVersion="{Binding ProjectGraphVersion}"
                        CenterOnSelectedNodeVersion="{Binding ProjectGraphCenterVersion}"
                        ThemeKey="{Binding ThemeKey}"
                        UiFontFamily="{Binding UiFontFamily}"
                        CodeFontFamily="{Binding CodeFontFamily}" />

                    <Border
                        x:Name="ProjectGraphSearchPanel"
                        Classes="graph-search-panel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,8,0,0"
                        IsVisible="{Binding IsProjectGraphSearchOpen}"
                        IsHitTestVisible="{Binding IsProjectGraphSearchOpen}">
                      <Grid RowDefinitions="Auto,Auto" Width="380">
                        <TextBox
                            x:Name="ProjectGraphSearchBox"
                            Classes="graph-search-input"
                            Watermark="Search graph"
                            Text="{Binding ProjectGraphSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            KeyDown="OnProjectGraphSearchKeyDown" />

                        <ItemsControl
                            Grid.Row="1"
                            Classes="graph-search-suggestions"
                            ItemsSource="{Binding ProjectGraphSearchSuggestions}"
                            IsVisible="{Binding HasProjectGraphSearchSuggestions}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ProjectGraphSearchSuggestionViewModel}">
                              <Button
                                  Classes="graph-search-suggestion"
                                  Command="{Binding DataContext.SelectProjectGraphSearchSuggestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8">
                                  <TextBlock
                                      Classes="graph-search-title"
                                      Text="{Binding Title}" />
                                  <TextBlock
                                      Grid.Column="1"
                                      Classes="graph-search-meta"
                                      Text="{Binding Meta}" />
                                  <TextBlock
                                      Grid.Row="1"
                                      Grid.ColumnSpan="2"
                                      Classes="graph-search-detail"
                                      Text="{Binding Detail}" />
                                </Grid>
                              </Button>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Grid>
                    </Border>
                  </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Classes="graph-tree-sidebar"
                    MinHeight="0"
                    IsVisible="{Binding IsProjectGraphTreePaneOpen}"
                    IsHitTestVisible="{Binding IsProjectGraphTreePaneOpen}">
                  <Grid RowDefinitions="Auto,*" RowSpacing="6" MinHeight="0">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                      <TextBlock Classes="graph-sidebar-title" Text="Current project tree" />
                      <Button
                          Grid.Column="1"
                          Classes="browser-nav-button"
                          Content="x"
                          ToolTip.Tip="Close graph project tree"
                          Command="{Binding ToggleProjectGraphTreePaneCommand}" />
                    </Grid>
                    <TextBox
                        Grid.Row="1"
                        Classes="graph-tree-text"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        TextWrapping="NoWrap"
                        Text="{Binding ProjectGraphTreeText}"
                        ScrollViewer.AllowAutoHide="True"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        controls:HoverScrollbarBehavior.IsEnabled="True"
                        controls:HoverScrollbarBehavior.ReserveRight="12" />
                  </Grid>
                </Border>
              </Grid>
            </Border>

            <Border
                Grid.Row="2"
                Classes="editor-body scanner-page"
                Padding="6"
                ClipToBounds="True"
                MinHeight="0"
                IsVisible="{Binding IsProjectScannerMode}">
              <Grid RowDefinitions="Auto,*" RowSpacing="6">
                <Border Classes="scanner-metric-strip">
                  <ItemsControl ItemsSource="{Binding ProjectScanMetrics}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type svc:ProjectStackMetric}">
                        <Border Classes="scanner-metric" ToolTip.Tip="{Binding Detail}">
                          <Grid RowDefinitions="Auto,*" RowSpacing="0">
                            <TextBlock Classes="scanner-metric-key" Text="{Binding Key}" />
                            <TextBlock Grid.Row="1" Classes="scanner-metric-value" Text="{Binding Value}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>

                <ScrollViewer
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    controls:HoverScrollbarBehavior.IsEnabled="True"
                    controls:HoverScrollbarBehavior.ReserveRight="12">
                  <Grid ColumnDefinitions="1.25*,*" ColumnSpacing="6">
                    <StackPanel Grid.Column="0" Spacing="6">
                      <Border Classes="scanner-panel scanner-panel-primary">
                        <Grid RowDefinitions="Auto,*" RowSpacing="5">
                          <TextBlock Classes="scanner-panel-title" Text="Project Signature" />
                          <ItemsControl Grid.Row="1" ItemsSource="{Binding ProjectScanIdentitySections}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate DataType="{x:Type svc:ProjectStackSection}">
                                <StackPanel Classes="scanner-section-group">
                                  <TextBlock Classes="scanner-section-title" Text="{Binding Title}" />
                                  <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Classes="scanner-section-item" Text="{Binding}" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Grid>
                      </Border>

                      <Border Classes="scanner-panel">
                        <Grid RowDefinitions="Auto,*" RowSpacing="5">
                          <TextBlock Classes="scanner-panel-title" Text="Files" />
                          <ItemsControl Grid.Row="1" ItemsSource="{Binding ProjectScanFileSections}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate DataType="{x:Type svc:ProjectStackSection}">
                                <StackPanel Classes="scanner-section-group">
                                  <TextBlock Classes="scanner-section-title" Text="{Binding Title}" />
                                  <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Classes="scanner-section-item" Text="{Binding}" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Grid>
                      </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="6">
                      <Border Classes="scanner-panel">
                        <Grid RowDefinitions="Auto,*" RowSpacing="5">
                          <TextBlock Classes="scanner-panel-title" Text="Rule Fit" />
                          <ItemsControl Grid.Row="1" ItemsSource="{Binding ProjectScanRuleSections}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate DataType="{x:Type svc:ProjectStackSection}">
                                <StackPanel Classes="scanner-section-group">
                                  <TextBlock Classes="scanner-section-title" Text="{Binding Title}" />
                                  <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Classes="scanner-section-item" Text="{Binding}" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Grid>
                      </Border>

                      <Border Classes="scanner-panel">
                        <Grid RowDefinitions="Auto,*" RowSpacing="5">
                          <TextBlock Classes="scanner-panel-title" Text="Scan Notes" />
                          <ItemsControl Grid.Row="1" ItemsSource="{Binding ProjectScanDiagnosticSections}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate DataType="{x:Type svc:ProjectStackSection}">
                                <StackPanel Classes="scanner-section-group">
                                  <TextBlock Classes="scanner-section-title" Text="{Binding Title}" />
                                  <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Classes="scanner-section-item" Text="{Binding}" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Grid>
                      </Border>
                    </StackPanel>
                  </Grid>
                </ScrollViewer>
              </Grid>
            </Border>

            <Border
                x:Name="ContextPromptBar"
                Grid.Row="3"
                Classes="cc-prompt-bar"
                Height="{Binding ContextControl.PromptBarHeight}"
                Opacity="{Binding ContextControl.PromptBarOpacity}"
                IsHitTestVisible="{Binding ContextControl.IsPromptOpen}"
                ClipToBounds="True"
                VerticalAlignment="Stretch"
                Margin="0">
              <Border.Transitions>
                <Transitions>
                  <DoubleTransition Property="Height" Duration="0:0:0.16" />
                  <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
                </Transitions>
              </Border.Transitions>
              <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="0">
                <ProgressBar
                    Classes="cc-prompt-progress"
                    Minimum="0"
                    Maximum="100"
                    Value="0"
                    Margin="0,0,0,7"
                    IsVisible="{Binding ContextControl.ShowBusyPromptProgress}"
                    IsIndeterminate="{Binding ContextControl.ShowBusyPromptProgress}" />

                <ItemsControl
                    Grid.Row="1"
                    Margin="0,0,0,6"
                    ItemsSource="{Binding ContextControl.ChatRequestProgressItems}"
                    IsVisible="{Binding ContextControl.HasChatRequestProgress}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ChatRequestProgressViewModel}">
                      <Border Classes="cc-transfer-progress" Margin="0,0,0,4">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="5">
                          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <TextBlock Classes="cc-transfer-title" Text="{Binding Title}" />
                            <TextBlock Grid.Column="1" Classes="cc-transfer-meta" Text="{Binding SizeLabel}" />
                            <TextBlock Grid.Column="2" Classes="cc-transfer-meta" Text="{Binding SpeedLabel}" />
                          </Grid>
                          <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <ProgressBar
                                Classes="cc-transfer-bar"
                                Minimum="0"
                                Maximum="100"
                                Value="{Binding Value}"
                                IsIndeterminate="{Binding IsIndeterminate}" />
                            <TextBlock Grid.Column="1" Classes="cc-transfer-percent" Text="{Binding ElapsedLabel}" />
                          </Grid>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border
                    Grid.Row="2"
                    Classes="cc-transfer-progress"
                    IsVisible="{Binding ContextControl.IsTransferProgressActive}">
                  <Grid RowDefinitions="Auto,Auto" RowSpacing="5">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                      <TextBlock Classes="cc-transfer-title" Text="{Binding ContextControl.TransferProgressTitle}" />
                      <TextBlock Grid.Column="1" Classes="cc-transfer-meta" Text="{Binding ContextControl.TransferProgressSizeLabel}" />
                      <TextBlock Grid.Column="2" Classes="cc-transfer-meta" Text="{Binding ContextControl.TransferProgressSpeedLabel}" />
                    </Grid>
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                      <ProgressBar
                          Classes="cc-transfer-bar"
                          Minimum="0"
                          Maximum="100"
                          Value="{Binding ContextControl.TransferProgressValue}"
                          IsIndeterminate="{Binding ContextControl.IsTransferProgressIndeterminate}" />
                      <TextBlock Grid.Column="1" Classes="cc-transfer-percent" Text="{Binding ContextControl.TransferProgressPercentLabel}" />
                    </Grid>
                  </Grid>
                </Border>

                <Border x:Name="ContextPromptComposer" Grid.Row="3" Classes="cc-prompt-composer">
                  <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button
                            Classes="cc-prompt-mode"
                            Classes.active="{Binding ContextControl.IsContextPromptMode}"
                            Content="CC"
                            ToolTip.Tip="Context Control prompt"
                            Command="{Binding ContextControl.SwitchPromptToContextCommand}" />
                        <Button
                            Classes="cc-prompt-mode"
                            Classes.active="{Binding ContextControl.IsTerminalPromptMode}"
                            Content="Term"
                            ToolTip.Tip="Install and model download terminal"
                            Command="{Binding ContextControl.SwitchPromptToTerminalCommand}" />
                      </StackPanel>
                      <Border Grid.Column="1" Classes="cc-prompt-status-pill">
                        <TextBlock Text="{Binding ContextControl.PhaseTitle}" Classes="cc-prompt-status" />
                      </Border>
                      <TextBlock Grid.Column="2" Text="{Binding ContextControl.PhaseDetail}" Classes="cc-prompt-detail" />
                      <Button
                          Grid.Column="3"
                          Classes="cc-prompt-icon"
                          Content="x"
                          ToolTip.Tip="Close prompt"
                          Command="{Binding ContextControl.ClosePromptCommand}" />
                    </Grid>

                    <TextBox
                        x:Name="ContextPromptTextBox"
                        Grid.Row="1"
                        Classes="cc-prompt-input"
                        IsVisible="{Binding ContextControl.IsMessagePromptMode}"
                        AcceptsReturn="True"
                        TextWrapping="{Binding ContextControl.PromptTextWrapping}"
                        Watermark="{Binding ContextControl.PromptWatermark}"
                        GotFocus="OnPromptTextBoxGotFocus"
                        LostFocus="OnPromptTextBoxLostFocus"
                        KeyDown="OnPromptTextBoxKeyDown"
                        TextChanged="OnPromptTextBoxTextChanged"
                        ScrollViewer.AllowAutoHide="True"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.HorizontalScrollBarVisibility="{Binding ContextControl.PromptHorizontalScrollBarVisibility}"
                        controls:HoverScrollbarBehavior.IsEnabled="True"
                        controls:HoverScrollbarBehavior.ReserveRight="12"
                        Text="{Binding ContextControl.PromptText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox
                        Grid.Row="1"
                        Classes="cc-terminal-output"
                        IsVisible="{Binding ContextControl.IsTerminalPromptMode}"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        TextWrapping="Wrap"
                        ScrollViewer.AllowAutoHide="True"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        controls:HoverScrollbarBehavior.IsEnabled="True"
                        controls:HoverScrollbarBehavior.ReserveRight="12"
                        Text="{Binding ContextControl.TerminalOutputText}" />

                    <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="7">
                      <StackPanel Orientation="Horizontal" Spacing="5" IsVisible="{Binding ContextControl.IsContextPromptMode}">
                        <Button Classes="cc-prompt-chip" Content="DIR" ToolTip.Tip="Create directory context" Command="{Binding ContextControl.RunDirCommand}" />
                        <Button Classes="cc-prompt-chip" Content="CC" ToolTip.Tip="Create selected code context" Command="{Binding ContextControl.RunCcCommand}" />
                        <Button Classes="cc-prompt-chip" Content="GO" ToolTip.Tip="Preview patch blocks" Command="{Binding ContextControl.RunGoCommand}" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="5" IsVisible="{Binding ContextControl.IsTerminalPromptMode}">
                        <Button Classes="cc-prompt-chip" Content="Clear" ToolTip.Tip="Clear terminal output" Command="{Binding ContextControl.ClearTerminalCommand}" />
                      </StackPanel>
                      <ComboBox
                          Grid.Column="1"
                          Classes="cc-local-model-picker"
                          IsVisible="{Binding ContextControl.IsContextPromptMode}"
                          ItemsSource="{Binding ContextControl.InstalledLocalModels}"
                          SelectedItem="{Binding ContextControl.SelectedLocalModel, Mode=TwoWay}"
                          MaxDropDownHeight="180">
                        <ComboBox.ItemTemplate>
                          <DataTemplate DataType="{x:Type vm:LocalLlmModelViewModel}">
                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <TextBlock Grid.Column="2" Text="{Binding ContextControl.PromptFooterSummary}" Classes="cc-prompt-meta" IsVisible="{Binding ContextControl.IsMessagePromptMode}" />
                      <TextBlock Grid.Column="2" Text="{Binding ContextControl.TransferProgressStatus}" Classes="cc-prompt-meta" IsVisible="{Binding ContextControl.IsTerminalPromptMode}" />
                      <Button
                          Grid.Column="3"
                          Classes="cc-prompt-send"
                          IsVisible="{Binding ContextControl.IsMessagePromptMode}"
                          Content="{Binding ContextControl.PromptSendButtonLabel}"
                          Command="{Binding ContextControl.SendCommand}" />
                    </Grid>
                  </Grid>
                </Border>
              </Grid>
            </Border>

          </Grid>
        </Border>
      </Grid>

      <Border
          Grid.Column="2"
          Classes="panel cc-dock"
          ClipToBounds="True"
          IsVisible="{Binding IsBrowserRoutingPaneOpen}"
          IsHitTestVisible="{Binding IsBrowserRoutingPaneOpen}">
        <Grid RowDefinitions="43,Auto,Auto,Auto,*" RowSpacing="8">
          <Border Grid.Row="0" Classes="pane-header" Padding="12,0">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Context Control" FontSize="12" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" />
              </StackPanel>
              <Button
                  Grid.Column="1"
                  Classes="tree-detail-toggle"
                  Content="x"
                  ToolTip.Tip="Close browser routing window"
                  Command="{Binding ToggleBrowserRoutingPaneCommand}" />
            </Grid>
          </Border>

          <Grid Grid.Row="1" Margin="10,0,10,0" ColumnDefinitions="*" ColumnSpacing="6">
            <Button
                Classes="cc-dock-tab"
                Classes.active="{Binding ContextControl.IsLogPanelOpen}"
                Content="LOG"
                Command="{Binding ContextControl.SelectLogPanelCommand}" />
          </Grid>

          <Grid Grid.Row="2" Margin="10,0,10,0" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
            <ComboBox
                Classes="cc-route-picker"
                HorizontalAlignment="Stretch"
                MaxDropDownHeight="180"
                ItemsSource="{Binding ContextControl.RouteOptions}"
                SelectedItem="{Binding ContextControl.SelectedRoute, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <StackPanel>
                <TextBlock Text="{Binding ContextControl.PhaseTitle}" Classes="cc-state-title" />
                <TextBlock Text="{Binding ContextControl.PhaseDetail}" Classes="cc-state-detail" />
              </StackPanel>
              <TextBlock
                  Grid.Column="1"
                  Classes="cc-busy"
                  Text="running"
                  IsVisible="{Binding ContextControl.IsBusy}" />
            </Grid>

            <Border Grid.Row="2" Classes="cc-root-info">
              <Grid ColumnDefinitions="38,*" ColumnSpacing="6">
                <TextBlock Text="root" Classes="cc-log-level" />
                <TextBlock
                    Grid.Column="1"
                    Text="{Binding ContextControl.ContextRootLabel}"
                    Classes="path-text"
                    ToolTip.Tip="{Binding ContextControl.ContextRootPath}" />
              </Grid>
            </Border>
          </Grid>

          <Grid Grid.Row="3" Margin="10,0,10,0" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="5">
            <TextBlock Text="{Binding ContextControl.PatchSummary}" Classes="cc-state-detail" />
            <Border Grid.Row="1" Classes="cc-log-host" MaxHeight="118" IsVisible="{Binding ContextControl.HasPatchPlanActions}">
              <ScrollViewer
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  controls:HoverScrollbarBehavior.IsEnabled="True"
                  controls:HoverScrollbarBehavior.ReserveRight="12">
                <ItemsControl ItemsSource="{Binding ContextControl.PatchPlanActions}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PatchPlanActionViewModel}">
                      <Grid ColumnDefinitions="34,34,*" ColumnSpacing="5" Margin="0,0,0,3">
                        <TextBlock Text="{Binding AddedLabel}" Classes="history-meta" TextAlignment="Right" FontWeight="Black" Foreground="{DynamicResource GoodBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding RemovedLabel}" Classes="history-meta" TextAlignment="Right" FontWeight="Black" Foreground="{DynamicResource BadBrush}" />
                        <TextBlock Grid.Column="2" Text="{Binding Summary}" Classes="cc-log-message" TextTrimming="CharacterEllipsis" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
            <TextBlock Grid.Row="2" Text="{Binding ContextControl.LastExportPath}" Classes="path-text" />
            <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="6">
              <Button
                  Classes="header-mini primary"
                  Content="Apply effective"
                  Command="{Binding ContextControl.ApplyPatchCommand}" />
              <Button
                  Grid.Column="1"
                  Classes="header-mini"
                  Content="Apply all"
                  Command="{Binding ContextControl.ApplyAllPatchCommand}" />
            </Grid>
          </Grid>

          <Grid Grid.Row="4" Margin="10,0,10,10" RowDefinitions="*,Auto" RowSpacing="8" MinHeight="0">
            <Border Grid.Row="0" Classes="cc-log-host" IsVisible="{Binding ContextControl.IsLogPanelOpen}">
              <ScrollViewer
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  controls:HoverScrollbarBehavior.IsEnabled="True"
                  controls:HoverScrollbarBehavior.ReserveRight="12">
                <ItemsControl ItemsSource="{Binding ContextControl.LogEntries}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ContextControlLogEntryViewModel}">
                      <Grid ColumnDefinitions="42,34,*" ColumnSpacing="5" Margin="0,0,0,3">
                        <TextBlock Text="{Binding Time}" Classes="history-meta" />
                        <TextBlock Grid.Column="1" Text="{Binding Level}" Classes="cc-log-level" />
                        <TextBlock Grid.Column="2" Text="{Binding Message}" Classes="cc-log-message" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>

            <Border Grid.Row="0" Classes="cc-log-host" IsVisible="False">
              <Grid RowDefinitions="Auto,*" RowSpacing="7" MinHeight="0">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                  <ComboBox
                      Classes="cc-route-picker"
                      HorizontalAlignment="Stretch"
                      ItemsSource="{Binding ContextControl.InstalledLocalModels}"
                      SelectedItem="{Binding ContextControl.SelectedLocalModel, Mode=TwoWay}"
                      MaxDropDownHeight="180">
                    <ComboBox.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:LocalLlmModelViewModel}">
                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <Button
                      Grid.Column="1"
                      Classes="browser-nav-button"
                      Content="↻"
                      ToolTip.Tip="Refresh local models"
                      Command="{Binding ContextControl.RefreshLocalModelsCommand}" />
                </Grid>

                <ScrollViewer
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    controls:HoverScrollbarBehavior.IsEnabled="True"
                    controls:HoverScrollbarBehavior.ReserveRight="12">
                  <ItemsControl ItemsSource="{Binding ContextControl.ChatMessages}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:LocalLlmChatMessageViewModel}">
                        <Border Classes="cc-chat-message" Classes.user="{Binding IsUser}">
                          <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                              <TextBlock Classes="cc-chat-role" Text="{Binding RoleLabel}" />
                              <TextBlock Grid.Column="1" Classes="history-meta" Text="{Binding Time}" />
                            </Grid>
                            <TextBlock Grid.Row="1" Classes="cc-chat-text" Text="{Binding Text}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </Border>

            <Grid
                x:Name="AttachmentRegion"
                Grid.Row="1"
                MinHeight="0"
                ClipToBounds="True"
                SizeChanged="OnAttachmentRegionSizeChanged">
              <Grid RowDefinitions="Auto,Auto" RowSpacing="6" MinHeight="0" VerticalAlignment="Bottom" IsVisible="{Binding ContextControl.HasAttachments}">
                <TextBlock Text="Attached Files:" Classes="cc-attachment-title" />
                <Border x:Name="AttachmentListHost" Grid.Row="1" Classes="cc-attachment-host">
                  <ListBox
                      x:Name="AttachmentList"
                      Classes="attachment-list"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"
                      BorderThickness="0"
                      ItemsSource="{Binding ContextControl.Attachments}"
                      SelectionMode="Single"
                      controls:HoverScrollbarBehavior.IsEnabled="True"
                      controls:HoverScrollbarBehavior.ReserveRight="12"
                      ScrollViewer.AllowAutoHide="True"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Styles>
                      <Style Selector="ListBox#AttachmentList > ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,4" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                      </Style>
                      <Style Selector="ListBox#AttachmentList > ListBoxItem:selected">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                      </Style>
                      <Style Selector="ListBox#AttachmentList > ListBoxItem:pointerover">
                        <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
                      </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:ContextControlAttachmentViewModel}">
                        <Border
                            Classes="cc-attachment-row"
                            HorizontalAlignment="Stretch"
                            Tapped="OnAttachmentRowTapped"
                            ToolTip.Tip="{Binding Path}">
                          <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="7">
                            <Border
                                Classes="cc-attachment-ext-tag"
                                Background="{Binding ExtensionTagBackground}"
                                BorderBrush="{Binding ExtensionTagBorder}">
                              <TextBlock
                                  Text="{Binding ExtensionTagText}"
                                  Foreground="{Binding ExtensionTagForeground}"
                                  Classes="cc-attachment-ext-tag-text" />
                            </Border>
                            <TextBlock
                                Grid.Column="1"
                                Text="{Binding DisplayTitle}"
                                Classes="path-text"
                                VerticalAlignment="Center" />
                            <Button
                                Grid.Column="2"
                                Classes="cc-prompt-chip"
                                Content="{Binding IncludeLabel}"
                                Command="{Binding DataContext.ContextControl.ToggleAttachmentIncludeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                            <Border
                                Grid.Column="3"
                                Classes="cc-attachment-remove"
                                Tapped="OnAttachmentRemoveTapped"
                                ToolTip.Tip="Remove attachment">
                              <TextBlock Text="x" Classes="cc-attachment-remove-text" />
                            </Border>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>
              </Grid>
            </Grid>
          </Grid>
        </Grid>
      </Border>
    </Grid>
    </Grid>
    <Border
        x:Name="PromptFileDropOverlay"
        Grid.RowSpan="2"
        Classes="cc-filedrop-overlay"
        IsVisible="False"
        IsHitTestVisible="False">
      <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Classes="cc-filedrop-panel">
          <StackPanel Spacing="10" HorizontalAlignment="Center">
            <Border Classes="cc-filedrop-icon-host" HorizontalAlignment="Center">
              <TextBlock Text="⇩" Classes="cc-filedrop-icon" />
            </Border>
            <TextBlock
                Text="Drop your files to attach them to the prompt"
                Classes="cc-filedrop-title"
                TextAlignment="Center" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
    <Border
        Grid.RowSpan="2"
        Classes="cc-modal-overlay"
        IsVisible="{Binding ContextControl.IsOllamaInstallerPromptOpen}"
        IsHitTestVisible="{Binding ContextControl.IsOllamaInstallerPromptOpen}">
      <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Classes="cc-modal-panel" Width="430">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <TextBlock
                  Text="Ollama setup"
                  Classes="cc-modal-title" />
              <Button
                  Grid.Column="1"
                  Classes="cc-prompt-icon"
                  Content="x"
                  ToolTip.Tip="Close"
                  Command="{Binding ContextControl.CloseOllamaInstallerPromptCommand}" />
            </Grid>
            <TextBlock
                Grid.Row="1"
                Text="{Binding ContextControl.OllamaInstallerPromptMessage}"
                Classes="cc-modal-message" />
            <Button
                Grid.Row="2"
                Classes="browser-open-button primary"
                Content="OK"
                HorizontalAlignment="Right"
                Command="{Binding ContextControl.CloseOllamaInstallerPromptCommand}" />
          </Grid>
        </Border>
      </Grid>
    </Border>
    <Border Classes="resize-edge resize-left" Grid.RowSpan="2" Width="8" HorizontalAlignment="Left" VerticalAlignment="Stretch" PointerPressed="OnResizeLeftPointerPressed" />
    <Border Classes="resize-edge resize-right" Grid.RowSpan="2" Width="8" HorizontalAlignment="Right" VerticalAlignment="Stretch" PointerPressed="OnResizeRightPointerPressed" />
    <Border Classes="resize-edge resize-top" Grid.RowSpan="2" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Top" PointerPressed="OnResizeTopPointerPressed" />
    <Border Classes="resize-edge resize-bottom" Grid.RowSpan="2" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" PointerPressed="OnResizeBottomPointerPressed" />
    <Border Classes="resize-edge resize-top-left" Grid.RowSpan="2" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Top" PointerPressed="OnResizeTopLeftPointerPressed" />
    <Border Classes="resize-edge resize-top-right" Grid.RowSpan="2" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top" PointerPressed="OnResizeTopRightPointerPressed" />
    <Border Classes="resize-edge resize-bottom-left" Grid.RowSpan="2" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Bottom" PointerPressed="OnResizeBottomLeftPointerPressed" />
    <Border Classes="resize-edge resize-bottom-right" Grid.RowSpan="2" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Bottom" PointerPressed="OnResizeBottomRightPointerPressed" />
  </Grid>
</Window>

