<Application
    x:Class="ContextControl.Workbench.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedThemeVariant="Light">
  <Application.Resources>
    <FontFamily x:Key="UiFontFamily">fonts:Inter, Segoe UI</FontFamily>
    <FontFamily x:Key="CodeFontFamily">avares://ContextControl.Workbench/Assets/Fonts#Cascadia Code, Consolas</FontFamily>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
    <StyleInclude Source="avares://ContextControl.Workbench/Styles/WorkbenchDesign.axaml" />
  </Application.Styles>
</Application>
