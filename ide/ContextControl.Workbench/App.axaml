<Application
    x:Class="ContextControl.Workbench.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedThemeVariant="Light">
  <Application.Resources>
    <FontFamily x:Key="UiFontFamily">Aptos, Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="CodeFontFamily">Cascadia Code, Cascadia Mono, Consolas, monospace</FontFamily>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
    <StyleInclude Source="avares://ContextControl.Workbench/Styles/WorkbenchDesign.axaml" />
  </Application.Styles>
</Application>
