<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls">

    <Style Selector="Border.workspace-mode-bar">
      <Setter Property="Background" Value="{DynamicResource TitleBarBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="CornerRadius" Value="8,8,0,0" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Button.workspace-mode-button">
      <Setter Property="Height" Value="22" />
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="FontSize" Value="9.5" />
      <Setter Property="FontWeight" Value="ExtraBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.workspace-mode-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.workspace-mode-button.active">
      <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.workspace-mode-button.active:pointerover">
      <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="TextBlock.browser-mode-status">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontSize" Value="9.5" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="Border.browser-tab">
      <Setter Property="Height" Value="22" />
      <Setter Property="MinWidth" Value="140" />
      <Setter Property="MaxWidth" Value="260" />
      <Setter Property="Padding" Value="7,0,3,0" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.browser-tab:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    </Style>

    <Style Selector="Border.browser-tab.active">
      <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    </Style>

    <Style Selector="TextBlock.browser-tab-title">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="Button.browser-tab-close">
      <Setter Property="Width" Value="16" />
      <Setter Property="Height" Value="16" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.browser-tab-close:pointerover">
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource BadBrush}" />
    </Style>

    <Style Selector="Border.browser-nav-bar">
      <Setter Property="Height" Value="42" />
      <Setter Property="MinHeight" Value="42" />
      <Setter Property="Background" Value="{DynamicResource HeaderBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Button.browser-nav-button">
      <Setter Property="Width" Value="22" />
      <Setter Property="Height" Value="22" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.browser-nav-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.browser-open-button">
      <Setter Property="Height" Value="22" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="FontSize" Value="9.5" />
      <Setter Property="FontWeight" Value="ExtraBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.browser-open-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.browser-open-button.primary">
      <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="ToggleButton.browser-open-button">
      <Setter Property="Height" Value="22" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="FontSize" Value="9.5" />
      <Setter Property="FontWeight" Value="ExtraBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="ToggleButton.browser-open-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="ToggleButton.browser-open-button:checked">
      <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="TextBlock.browser-loading-label">
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="MinWidth" Value="44" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBox.browser-url-input">
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Padding" Value="7,0" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Border.browser-surface">
      <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Button.external-update-row">
      <Setter Property="Height" Value="18" />
      <Setter Property="MinHeight" Value="18" />
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="Margin" Value="0,0,0,1" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.external-update-row:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    </Style>

    <Style Selector="TextBlock.update-file">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="ExtraBold" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.update-meta">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.update-empty">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

</Styles>
