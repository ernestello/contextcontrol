<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls">
  <Style Selector="Button.dialog-command">
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="8,0" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.dialog-command.primary">
    <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Button.dialog-command.primary:pointerover">
    <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Border.cc-dock">
    <Setter Property="MinWidth" Value="250" />
  </Style>

  <Style Selector="Border.resize-edge">
    <Setter Property="Background" Value="#00000000" />
  </Style>

  <Style Selector="Border.resize-edge.resize-left">
    <Setter Property="Cursor" Value="SizeWestEast" />
  </Style>

  <Style Selector="Border.resize-edge.resize-right">
    <Setter Property="Cursor" Value="SizeWestEast" />
  </Style>

  <Style Selector="Border.resize-edge.resize-top">
    <Setter Property="Cursor" Value="SizeNorthSouth" />
  </Style>

  <Style Selector="Border.resize-edge.resize-bottom">
    <Setter Property="Cursor" Value="SizeNorthSouth" />
  </Style>

  <Style Selector="Border.resize-edge.resize-top-left">
    <Setter Property="Cursor" Value="TopLeftCorner" />
  </Style>

  <Style Selector="Border.resize-edge.resize-top-right">
    <Setter Property="Cursor" Value="TopRightCorner" />
  </Style>

  <Style Selector="Border.resize-edge.resize-bottom-left">
    <Setter Property="Cursor" Value="BottomLeftCorner" />
  </Style>

  <Style Selector="Border.resize-edge.resize-bottom-right">
    <Setter Property="Cursor" Value="BottomRightCorner" />
  </Style>

  <Style Selector="TextBlock.cc-state-title">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="ExtraBold" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style Selector="TextBlock.cc-state-detail">
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="13" />
  </Style>

  <Style Selector="TextBlock.cc-busy">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="Black" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.cc-mini-title">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="ExtraBold" />
  </Style>

  <Style Selector="Button.cc-dock-tab">
    <Setter Property="Height" Value="24" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="7,0" />
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.cc-dock-tab:pointerover">
    <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Button.cc-dock-tab.active">
    <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="ComboBox.cc-route-picker">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="MaxWidth" Value="280" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Border.editor-body">
    <Setter Property="Background" Value="#00000000" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="MinHeight" Value="0" />
  </Style>

  <Style Selector="Border.cc-root-info">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="6,2" />
  </Style>

  <Style Selector="Border.cc-log-host">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="7" />
  </Style>

  <Style Selector="TextBlock.cc-log-level">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="Black" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style Selector="TextBlock.cc-log-message">
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="13" />
  </Style>
</Styles>
