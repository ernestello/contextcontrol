<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls">
  <Style Selector="Border.chat-history-panel">
    <Setter Property="Width" Value="220" />
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="7" />
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="Grid.chat-history-hover-shell">
    <Setter Property="Width" Value="10" />
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Width" Duration="0:0:0.16" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="ItemsControl.chat-session-list">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Button.chat-session-row">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="MinHeight" Value="46" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="Padding" Value="7,5" />
    <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
  </Style>

  <Style Selector="Button.chat-session-row:pointerover">
    <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
  </Style>

  <Style Selector="Button.chat-session-row.active">
    <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
  </Style>

  <Style Selector="TextBlock.chat-session-title">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="FontWeight" Value="ExtraBold" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style Selector="Button.chat-session-remove">
    <Setter Property="Width" Value="19" />
    <Setter Property="Height" Value="19" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Black" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.chat-session-remove:pointerover">
    <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource BadBrush}" />
  </Style>

  <Style Selector="Border.cc-chat-message">
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="7,5" />
    <Setter Property="Margin" Value="0,0,0,6" />
  </Style>

  <Style Selector="Border.cc-chat-message.user">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
  </Style>

  <Style Selector="TextBlock.cc-chat-role">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="Black" />
  </Style>

  <Style Selector="TextBlock.cc-chat-text, SelectableTextBlock.cc-chat-text, controls|MarkdownTextBlock.cc-chat-text">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="13" />
  </Style>

  <Style Selector="Button.chat-text-copy">
    <Setter Property="Width" Value="24" />
    <Setter Property="Height" Value="22" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Black" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.chat-text-copy:pointerover">
    <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="Border.chat-snippet">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="Margin" Value="0,3,0,5" />
  </Style>

  <Style Selector="Border.chat-snippet-type">
    <Setter Property="MinWidth" Value="44" />
    <Setter Property="Height" Value="18" />
    <Setter Property="Padding" Value="6,0" />
    <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="TextBlock.chat-snippet-type-text">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="8.5" />
    <Setter Property="FontWeight" Value="Black" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style Selector="TextBlock.chat-snippet-title">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Black" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style Selector="TextBlock.chat-snippet-meta">
    <Setter Property="Foreground" Value="{DynamicResource TreeVersionFixedBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style Selector="TextBlock.cc-chat-phase">
    <Setter Property="Foreground" Value="{DynamicResource TreeVersionFixedBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="9.5" />
    <Setter Property="FontWeight" Value="Black" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style Selector="Button.chat-snippet-action">
    <Setter Property="Height" Value="18" />
    <Setter Property="MinHeight" Value="18" />
    <Setter Property="MinWidth" Value="32" />
    <Setter Property="Padding" Value="6,0" />
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="8.5" />
    <Setter Property="FontWeight" Value="ExtraBold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.chat-snippet-action:pointerover">
    <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="Border.chat-snippet-divider">
    <Setter Property="Height" Value="1" />
    <Setter Property="Background" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Opacity" Value="0.88" />
  </Style>

  <Style Selector="TextBlock.chat-snippet-preview">
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="LineHeight" Value="14" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="MaxHeight" Value="72" />
  </Style>

  <Style Selector="Border.chat-snippet-code-surface">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="MaxHeight" Value="260" />
    <Setter Property="Padding" Value="6,4" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="SelectableTextBlock.chat-snippet-code-text">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="LineHeight" Value="15" />
    <Setter Property="TextWrapping" Value="NoWrap" />
  </Style>

  <Style Selector="TextBox.chat-snippet-code">
    <Setter Property="MinHeight" Value="76" />
    <Setter Property="MaxHeight" Value="260" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="LineHeight" Value="15" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="controls|CodeEditor.chat-snippet-code-editor">
    <Setter Property="MinHeight" Value="88" />
    <Setter Property="MaxHeight" Value="260" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="controls|CodeEditor.chat-snippet-code-editor.preview">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="MaxHeight" Value="32" />
  </Style>

  <Style Selector="Border.chat-thinking">
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="6" />
  </Style>

  <Style Selector="Border.chat-attachment-chip">
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="Margin" Value="0,0,5,5" />
  </Style>

  <Style Selector="TextBlock.chat-attachment-chip-text">
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style Selector="Border.skillbook-entry">
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8" />
  </Style>

  <Style Selector="TextBox.skillbook-text">
    <Setter Property="MinHeight" Value="100" />
    <Setter Property="MaxHeight" Value="320" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="LineHeight" Value="15" />
    <Setter Property="Padding" Value="7" />
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>
</Styles>
