<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls">
  <Style Selector="Border.cc-attachment-host">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="7" />
    <Setter Property="MinHeight" Value="96" />
  </Style>

  <Style Selector="ListBox.attachment-list">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Transitions">
      <Transitions>
        <ThicknessTransition Property="Padding" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="TextBlock.cc-attachment-title">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="ExtraBold" />
    <Setter Property="TextAlignment" Value="Center" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.cc-attachment-row">
    <Setter Property="MinHeight" Value="22" />
    <Setter Property="Padding" Value="5,2,4,2" />
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="MinWidth" Value="0" />
  </Style>

  <Style Selector="Border.cc-attachment-row:pointerover">
    <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
  </Style>

  <Style Selector="Border.cc-attachment-ext-tag">
    <Setter Property="MinWidth" Value="34" />
    <Setter Property="Height" Value="16" />
    <Setter Property="Padding" Value="5,0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.cc-attachment-ext-tag-text">
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="8.5" />
    <Setter Property="FontWeight" Value="Black" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextAlignment" Value="Center" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style Selector="Border.cc-attachment-remove">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.cc-attachment-remove:pointerover">
    <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BadBrush}" />
  </Style>

  <Style Selector="TextBlock.cc-attachment-remove-text">
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Black" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.cc-filedrop-overlay">
    <Setter Property="Background" Value="#BF03060B" />
  </Style>

  <Style Selector="Border.cc-filedrop-panel">
    <Setter Property="Padding" Value="18,16" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="#E610141B" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Border.cc-filedrop-icon-host">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="40" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="TextBlock.cc-filedrop-icon">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="Black" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.cc-filedrop-title">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="ExtraBold" />
  </Style>

  <Style Selector="Border.cc-modal-overlay">
    <Setter Property="Background" Value="#9903060B" />
  </Style>

  <Style Selector="Border.cc-modal-panel">
    <Setter Property="Padding" Value="16,14" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow" Value="0 16 34 0 #66000000" />
  </Style>

  <Style Selector="TextBlock.cc-modal-title">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="ExtraBold" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.cc-modal-message">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="LineHeight" Value="16" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
</Styles>
