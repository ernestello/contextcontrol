<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls">

    <Style Selector="Border.settings-panel">
      <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10" />
    </Style>

    <Style Selector="Border.side-rail">
      <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="5" />
    </Style>

    <Style Selector="Button.settings-nav">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.settings-nav:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    </Style>

    <Style Selector="Button.settings-nav.active">
      <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.settings-title">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="ExtraBold" />
    </Style>

    <Style Selector="TextBlock.field-label">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.path-text">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.appearance-parent-label">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.appearance-param-label">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.summary-kind-category">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Grid.editor-style-table">
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Border.editor-style-cell">
      <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="MinHeight" Value="72" />
    </Style>

    <Style Selector="Border.editor-style-cell.left">
      <Setter Property="CornerRadius" Value="5,0,0,5" />
    </Style>

    <Style Selector="Border.editor-style-cell.right">
      <Setter Property="CornerRadius" Value="0,5,5,0" />
      <Setter Property="BorderThickness" Value="0,1,1,1" />
    </Style>

    <Style Selector="Border.summary-options-table">
      <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="Margin" Value="10,3,0,0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Border.summary-options-row">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="5,2" />
    </Style>

    <Style Selector="Border.summary-options-row.last">
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Border.summary-kind-table">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="Margin" Value="0,1,0,0" />
    </Style>

    <Style Selector="Border.summary-kind-cell">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,1,0" />
      <Setter Property="Padding" Value="6,2" />
      <Setter Property="MinHeight" Value="90" />
    </Style>

    <Style Selector="Border.summary-kind-cell.last">
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Button.summary-expander">
      <Setter Property="Width" Value="16" />
      <Setter Property="Height" Value="16" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.summary-expander:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="ComboBox.theme-picker">
      <Setter Property="MinHeight" Value="20" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Background" Value="{DynamicResource DropdownBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DropdownBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="MaxDropDownHeight" Value="320" />
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>

    <Style Selector="ComboBox.theme-picker /template/ Popup#PART_Popup">
      <Setter Property="Placement" Value="BottomEdgeAlignedLeft" />
    </Style>

    <Style Selector="ComboBox.theme-picker ComboBoxItem">
      <Setter Property="MinHeight" Value="18" />
      <Setter Property="Padding" Value="2,0" />
      <Setter Property="Background" Value="{DynamicResource DropdownBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="ComboBox.theme-picker ComboBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource DropdownHoverBrush}" />
    </Style>

    <Style Selector="ComboBox.theme-picker ComboBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource DropdownSelectedBrush}" />
    </Style>

    <Style Selector="ComboBox.theme-picker /template/ Popup#PART_Popup /template/ Border">
      <Setter Property="Background" Value="{DynamicResource DropdownBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DropdownBorderBrush}" />
    </Style>

    <Style Selector="TextBox.setting-search">
      <Setter Property="MinHeight" Value="20" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Padding" Value="5,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="CornerRadius" Value="5" />
    </Style>

    <Style Selector="CheckBox.appearance-toggle">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="MinHeight" Value="16" />
      <Setter Property="Height" Value="16" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="Template">
        <ControlTemplate>
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
            <Border
                x:Name="SwitchFrame"
                Width="22"
                Height="12"
                Background="{DynamicResource CommandBackgroundBrush}"
                BorderBrush="{DynamicResource CommandBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                VerticalAlignment="Center">
              <Ellipse
                  x:Name="SwitchThumb"
                  Width="6"
                  Height="6"
                  Fill="{DynamicResource TextMutedBrush}"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  Margin="3,0,0,0" />
            </Border>
            <ContentPresenter
                x:Name="PART_ContentPresenter"
                Grid.Column="1"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}"
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="Center" />
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="CheckBox.appearance-toggle /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Margin" Value="0" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="CheckBox.appearance-toggle:pointerover /template/ Border#SwitchFrame">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    </Style>

    <Style Selector="CheckBox.appearance-toggle:checked /template/ Border#SwitchFrame">
      <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    </Style>

    <Style Selector="CheckBox.appearance-toggle:checked /template/ Ellipse#SwitchThumb">
      <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="Margin" Value="0,0,3,0" />
    </Style>

    <Style Selector="CheckBox.appearance-toggle:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>

    <Style Selector="CheckBox.summary-kind-check">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="MinHeight" Value="15" />
      <Setter Property="Height" Value="15" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="4,0,0,0" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
            <Border
                x:Name="SummaryCheckBox"
                Width="11"
                Height="11"
                Background="{DynamicResource CommandBackgroundBrush}"
                BorderBrush="{DynamicResource CommandBorderBrush}"
                BorderThickness="1"
                CornerRadius="2"
                VerticalAlignment="Center">
              <TextBlock
                  x:Name="SummaryCheckGlyph"
                  Text="✓"
                  Opacity="0"
                  Foreground="{DynamicResource AccentBrush}"
                  FontFamily="{DynamicResource CodeFontFamily}"
                  FontSize="9"
                  FontWeight="Bold"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="0,-1,0,0" />
            </Border>
            <ContentPresenter
                x:Name="PART_ContentPresenter"
                Grid.Column="1"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}"
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="Center" />
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="CheckBox.summary-kind-check:checked /template/ Border#SummaryCheckBox">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    </Style>

    <Style Selector="CheckBox.summary-kind-check:checked /template/ TextBlock#SummaryCheckGlyph">
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="CheckBox.summary-kind-check:pointerover /template/ Border#SummaryCheckBox">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    </Style>

    <Style Selector="Border.syntax-preview-card">
      <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="Padding" Value="7" />
    </Style>

    <Style Selector="TextBlock.preview-caption">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.rule-card">
      <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="5" />
  </Style>

  <Style Selector="Border.rule-list-host">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="4" />
  </Style>

  <Style Selector="Border.rule-row">
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="3,0" />
      <Setter Property="Margin" Value="0,0,3,3" />
      <Setter Property="MinHeight" Value="15" />
    </Style>

    <Style Selector="TextBlock.rule-value">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
</Styles>
