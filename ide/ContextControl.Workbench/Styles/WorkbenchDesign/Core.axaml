<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls">

  <Styles.Resources>
    <ControlTheme x:Key="ContextControlScrollBarTheme" TargetType="ScrollBar">
      <Setter Property="ShowDelay" Value="0:0:0.05" />
      <Setter Property="HideDelay" Value="0:0:0.45" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="4" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{TemplateBinding CornerRadius}"
              Padding="{TemplateBinding Padding}">
            <Grid ClipToBounds="True">
              <Border Classes="scrollbar-track" />
              <Track
                  Name="PART_Track"
                  Minimum="{TemplateBinding Minimum}"
                  Maximum="{TemplateBinding Maximum}"
                  Value="{TemplateBinding Value, Mode=TwoWay}"
                  DeferThumbDrag="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                  ViewportSize="{TemplateBinding ViewportSize}"
                  Orientation="{TemplateBinding Orientation}">
                <Track.DecreaseButton>
                  <RepeatButton Classes="scrollbar-page" Focusable="False" />
                </Track.DecreaseButton>
                <Track.IncreaseButton>
                  <RepeatButton Classes="scrollbar-page" Focusable="False" />
                </Track.IncreaseButton>
                <Track.Thumb>
                  <Thumb Classes="scrollbar-thumb" Focusable="False" />
                </Track.Thumb>
              </Track>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter>
    </ControlTheme>
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Border.main-window-shell">
    <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="1" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="Window.custom-maximized Border.main-window-shell">
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Window.custom-maximized Border.custom-titlebar">
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="ScrollBar">
    <Setter Property="Theme" Value="{StaticResource ContextControlScrollBarTheme}" />
    <Setter Property="ShowDelay" Value="0:0:0.05" />
    <Setter Property="HideDelay" Value="0:0:0.45" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4" />
  </Style>

  <Style Selector="ScrollBar:vertical">
    <Setter Property="Width" Value="12" />
    <Setter Property="MinWidth" Value="12" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <Style Selector="ScrollBar:horizontal">
    <Setter Property="Height" Value="12" />
    <Setter Property="MinHeight" Value="12" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <Style Selector="ScrollBar:vertical Track#PART_Track">
    <Setter Property="IsDirectionReversed" Value="True" />
  </Style>

  <Style Selector="ScrollBar.scrollbar-expanded">
    <Setter Property="Padding" Value="1" />
  </Style>

  <Style Selector="ScrollBar Border.scrollbar-track">
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Opacity" Value="0.34" />
  </Style>

  <Style Selector="ScrollBar.scrollbar-expanded Border.scrollbar-track">
    <Setter Property="Opacity" Value="0.78" />
  </Style>

  <Style Selector="ScrollBar:pointerover Border.scrollbar-track">
    <Setter Property="Opacity" Value="0.9" />
  </Style>

  <Style Selector="RepeatButton.scrollbar-page">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}" />
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="ScrollBar Thumb.scrollbar-thumb">
    <Setter Property="Background" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="MinWidth" Value="4" />
    <Setter Property="MinHeight" Value="4" />
    <Setter Property="Opacity" Value="0.52" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{TemplateBinding CornerRadius}" />
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="ScrollBar.scrollbar-expanded Thumb.scrollbar-thumb">
    <Setter Property="MinWidth" Value="10" />
    <Setter Property="MinHeight" Value="10" />
    <Setter Property="Background" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Opacity" Value="0.9" />
  </Style>

  <Style Selector="ScrollBar:pointerover Thumb.scrollbar-thumb">
    <Setter Property="Background" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    <Setter Property="Opacity" Value="0.92" />
  </Style>

  <Style Selector="ScrollBar Thumb.scrollbar-thumb:pointerover">
    <Setter Property="Background" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Border.title-icon">
    <Setter Property="Width" Value="15" />
    <Setter Property="Height" Value="15" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.title-icon-glyph">
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.window-title">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

<Style Selector="Border.panel">
      <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BoxShadow" Value="0 8 24 0 #14000000" />
    </Style>

    <Style Selector="Border.pane-header">
      <Setter Property="Background" Value="{DynamicResource HeaderBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="CornerRadius" Value="7,7,0,0" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="FlyoutPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ComboBoxItem">
      <Setter Property="Background" Value="{DynamicResource DropdownBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="ComboBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource DropdownHoverBrush}" />
    </Style>

    <Style Selector="ComboBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource DropdownSelectedBrush}" />
    </Style>

    <Style Selector="ContextMenu.project-tree-context-menu">
      <Setter Property="Background" Value="{DynamicResource DropdownBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="2" />
    </Style>

    <Style Selector="MenuItem.project-tree-context-item">
      <Setter Property="Height" Value="22" />
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="Padding" Value="9,1" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Background" Value="{DynamicResource DropdownBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="MenuItem.project-tree-context-item:pointerover">
      <Setter Property="Background" Value="{DynamicResource DropdownHoverBrush}" />
    </Style>

    <Style Selector="Separator.project-tree-context-separator">
      <Setter Property="Margin" Value="3,2" />
      <Setter Property="Height" Value="1" />
    </Style>

    <Style Selector="Button.command">
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="11,1,11,0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.command.primary">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.icon">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Button.edit-menu">
      <Setter Property="Height" Value="30" />
      <Setter Property="MinWidth" Value="76" />
      <Setter Property="Padding" Value="6,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.edit-dropdown">
      <Setter Property="MinWidth" Value="106" />
      <Setter Property="Padding" Value="3" />
      <Setter Property="Background" Value="{DynamicResource DropdownBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DropdownBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="BoxShadow" Value="0 7 20 0 #22000000" />
    </Style>

    <Style Selector="Border.edit-dropdown.view-dropdown">
      <Setter Property="MinWidth" Value="176" />
    </Style>

    <Style Selector="Button.edit-dropdown-item">
      <Setter Property="Height" Value="21" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="7,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.edit-dropdown-item:pointerover">
      <Setter Property="Background" Value="{DynamicResource DropdownHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DropdownBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.edit-menu:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    </Style>

    <Style Selector="Button.edit-menu:pressed">
      <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    </Style>

    <Style Selector="Border.edit-menu-icon">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Border.custom-titlebar">
      <Setter Property="Background" Value="{DynamicResource TitleBarBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TitleBarBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="CornerRadius" Value="7,7,0,0" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="Padding" Value="9,0,7,0" />
      <Setter Property="BoxShadow" Value="0 2 8 0 #12000000" />
    </Style>

    <Style Selector="Button.window-control">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="26" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.window-control:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.window-control.close:pointerover">
      <Setter Property="Background" Value="{DynamicResource BadBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="Button.project-tile">
      <Setter Property="Width" Value="118" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Margin" Value="0,0,5,0" />
      <Setter Property="Padding" Value="5,4" />
      <Setter Property="Background" Value="{DynamicResource ProjectTileBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Opacity" Value="0.62" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.09" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.project-tile.active">
      <Setter Property="Background" Value="{DynamicResource ProjectTileActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Border.project-tile-icon">
      <Setter Property="Width" Value="20" />
      <Setter Property="Height" Value="20" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBlock.project-tab-name">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.project-info-line">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="Button.project-window-toggle">
      <Setter Property="Width" Value="10" />
      <Setter Property="Height" Value="10" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Opacity" Value="0.55" />
    </Style>

    <Style Selector="Button.project-window-toggle:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
      <Setter Property="Opacity" Value="0.9" />
    </Style>

    <Style Selector="Button.project-window-toggle.active">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.project-info-switch">
      <Setter Property="Height" Value="19" />
      <Setter Property="MinHeight" Value="19" />
      <Setter Property="Width" Value="112" />
      <Setter Property="Padding" Value="7,0" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="9.5" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="Button.project-info-switch:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.header-mini">
      <Setter Property="Height" Value="20" />
      <Setter Property="MinHeight" Value="20" />
      <Setter Property="Padding" Value="6,0" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

  <Style Selector="Button.header-mini.primary">
    <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Button.header-mini.active">
    <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Button.header-mini.primary:pointerover">
    <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Button.inline-action">
    <Setter Property="MinHeight" Value="20" />
    <Setter Property="Padding" Value="7,1" />
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.tree-detail-toggle">
      <Setter Property="Height" Value="20" />
      <Setter Property="MinHeight" Value="20" />
      <Setter Property="Padding" Value="6,0" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

  <Style Selector="Button.tree-detail-toggle.active">
      <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

</Styles>
