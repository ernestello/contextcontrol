<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ContextControl.Workbench.Controls">

  <Style Selector="Window">
    <Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Border.title-icon">
    <Setter Property="Width" Value="15" />
    <Setter Property="Height" Value="15" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.title-icon-glyph">
    <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.window-title">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

<Style Selector="Border.panel">
      <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BoxShadow" Value="0 8 24 0 #14000000" />
    </Style>

    <Style Selector="Border.pane-header">
      <Setter Property="Background" Value="{DynamicResource HeaderBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="CornerRadius" Value="7,7,0,0" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Button.command">
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="11,1,11,0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.command.primary">
      <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.icon">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Button.scope-pin">
      <Setter Property="Width" Value="9" />
      <Setter Property="Height" Value="9" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{DynamicResource ScopePinBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ScopePinBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.custom-titlebar">
      <Setter Property="Background" Value="{DynamicResource HeaderBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="9,0,7,0" />
    </Style>

    <Style Selector="Button.window-control">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="26" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.window-control:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.window-control.close:pointerover">
      <Setter Property="Background" Value="{DynamicResource BadBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="Button.project-tile">
      <Setter Property="Width" Value="68" />
      <Setter Property="Height" Value="74" />
      <Setter Property="Margin" Value="0,0,7,0" />
      <Setter Property="Padding" Value="5" />
      <Setter Property="Background" Value="{DynamicResource ProjectTileBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Opacity" Value="0.62" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.09" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.project-tile.active">
      <Setter Property="Background" Value="{DynamicResource ProjectTileActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.project-info-switch">
      <Setter Property="Height" Value="19" />
      <Setter Property="MinHeight" Value="19" />
      <Setter Property="Width" Value="112" />
      <Setter Property="Padding" Value="7,0" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="9.5" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="Button.project-info-switch:pointerover">
      <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.header-mini">
      <Setter Property="Height" Value="20" />
      <Setter Property="MinHeight" Value="20" />
      <Setter Property="Padding" Value="6,0" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

  <Style Selector="Button.header-mini.primary">
    <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="Button.inline-action">
    <Setter Property="MinHeight" Value="20" />
    <Setter Property="Padding" Value="7,1" />
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.tree-detail-toggle">
      <Setter Property="Height" Value="20" />
      <Setter Property="MinHeight" Value="20" />
      <Setter Property="Padding" Value="6,0" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.tree-detail-toggle.active">
      <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.external-update-row">
      <Setter Property="Height" Value="18" />
      <Setter Property="MinHeight" Value="18" />
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="Margin" Value="0,0,0,1" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.external-update-row:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    </Style>

    <Style Selector="TextBlock.update-file">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="ExtraBold" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.update-meta">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.update-empty">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.project-stat">
      <Setter Property="Height" Value="14" />
      <Setter Property="MinHeight" Value="14" />
      <Setter Property="Padding" Value="5,0" />
      <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style Selector="TextBlock.project-stat-key">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.project-stat-value">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="TextAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.meta-key">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
    </Style>

    <Style Selector="TextBlock.meta-value">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="TextAlignment" Value="Right" />
    </Style>

    <Style Selector="ListBox.project-tree">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="4,4,16,9" />
    </Style>

    <Style Selector="ListBox.project-tree ListBoxItem">
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="IsHitTestVisible" Value="{Binding HasNode}" />
      <Setter Property="Focusable" Value="{Binding HasNode}" />
    </Style>

    <Style Selector="Button.tree-toggle">
      <Setter Property="Width" Value="11" />
      <Setter Property="Height" Value="11" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.tree-toggle:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    </Style>

    <Style Selector="Border.dir-row-highlight">
      <Setter Property="Background" Value="{DynamicResource DirectoryHighlightBrush}" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style Selector="Border.current-row-highlight">
      <Setter Property="Background" Value="{DynamicResource CurrentRowBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CurrentRowBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style Selector="TextBlock.node-type">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="MinWidth" Value="52" />
      <Setter Property="TextAlignment" Value="Right" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <Style Selector="TextBlock.node-type.dir">
      <Setter Property="Foreground" Value="{DynamicResource NodeTextBrush}" />
    </Style>

    <Style Selector="TextBlock.node-type.obj">
      <Setter Property="Foreground" Value="{DynamicResource NodeTextBrush}" />
    </Style>

    <Style Selector="TextBlock.node-type.skip">
      <Setter Property="Foreground" Value="{DynamicResource SkipTextBrush}" />
    </Style>

    <Style Selector="TextBlock.node-file-count">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="Foreground" Value="{DynamicResource MetricFileBrush}" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="TextAlignment" Value="Right" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.node-loc-count">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="Foreground" Value="{DynamicResource MetricLocBrush}" />
      <Setter Property="MinWidth" Value="62" />
      <Setter Property="TextAlignment" Value="Right" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.node-version">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="MinWidth" Value="28" />
      <Setter Property="TextAlignment" Value="Right" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="controls|IncludeExternalButton.include-external">
      <Setter Property="Width" Value="38" />
      <Setter Property="Height" Value="15" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="{DynamicResource IncludeBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource IncludeBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="7.5" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource IncludeTextBrush}" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.16" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="controls|IncludeExternalButton.include-external:pointerover">
      <Setter Property="Background" Value="{DynamicResource CommandPrimaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="TextBlock.folder-name">
      <Setter Property="Foreground" Value="{DynamicResource FolderTextBrush}" />
      <Setter Property="FontWeight" Value="ExtraBold" />
    </Style>

    <Style Selector="TextBlock.file-name">
      <Setter Property="Foreground" Value="{DynamicResource FileTextBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.external-name">
      <Setter Property="Foreground" Value="{DynamicResource ExternalTextBrush}" />
      <Setter Property="FontStyle" Value="Italic" />
    </Style>

    <Style Selector="TextBlock.editor-meta">
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.editor-line-number">
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="TextAlignment" Value="Right" />
    </Style>

    <Style Selector="TextBlock.editor-token">
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="LineHeight" Value="17" />
    </Style>

    <Style Selector="Border.history-version">
      <Setter Property="Height" Value="22" />
      <Setter Property="Padding" Value="6,0" />
      <Setter Property="Margin" Value="0,0,0,1" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
    </Style>

    <Style Selector="Border.history-version:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    </Style>

    <Style Selector="Border.history-version.active">
      <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    </Style>

    <Style Selector="TextBlock.history-meta">
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>



    <Style Selector="Border.settings-panel">
      <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10" />
    </Style>

    <Style Selector="Border.side-rail">
      <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="5" />
    </Style>

    <Style Selector="Button.settings-nav">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.settings-nav:pointerover">
      <Setter Property="Background" Value="{DynamicResource HistoryHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    </Style>

    <Style Selector="Button.settings-nav.active">
      <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="TextBlock.settings-title">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="ExtraBold" />
    </Style>

    <Style Selector="TextBlock.field-label">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.path-text">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="ComboBox.theme-picker">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Background" Value="{DynamicResource CommandBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="ComboBox.theme-picker /template/ Popup#PART_Popup">
      <Setter Property="Placement" Value="LeftEdgeAlignedTop" />
    </Style>

    <Style Selector="Border.syntax-preview-card">
      <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
