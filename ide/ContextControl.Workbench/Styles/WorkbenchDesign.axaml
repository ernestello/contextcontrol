    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="ExtraBold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.cc-prompt-send:pointerover">
    <Setter Property="Background" Value="{DynamicResource HistoryActiveBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Button.cc-prompt-icon">
